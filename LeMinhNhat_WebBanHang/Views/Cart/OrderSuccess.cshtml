@model LeMinhNhat_WebBanHang.Models.Order
@{
    ViewData["Title"] = "Đặt Hàng Thành Công";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8 animate__animated animate__zoomIn">
            <div class="card border-0 shadow-lg rounded-4 p-5 bg-white">
                <div class="d-inline-flex bg-success bg-opacity-10 text-success p-4 rounded-circle mb-4 mx-auto">
                    <i class="bi bi-patch-check-fill display-3"></i>
                </div>
                
                <h2 class="fw-bold text-success mb-2">ĐẶT HÀNG THÀNH CÔNG!</h2>
                <p class="text-muted mb-4 fs-5">Mã số hóa đơn của bạn là: <strong class="text-dark">#@Model.Id</strong>. Cảm ơn bạn đã lựa chọn TechStore.</p>

                <!-- Order Detail Summary Card -->
                <div class="card bg-light border-0 rounded-4 text-start p-4 mb-4">
                    <h6 class="fw-bold mb-3 border-bottom pb-2 text-dark"><i class="bi bi-info-circle-fill me-2 text-primary"></i>Thông Tin Chi Tiết Đơn Hàng</h6>
                    <div class="row g-2 mb-3 small">
                        <div class="col-md-6"><strong>Ngày Đặt Hàng:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                        <div class="col-md-6"><strong>Trạng Thái Đơn:</strong> <span class="badge bg-warning text-dark">Chờ Duyệt</span></div>
                        <div class="col-md-6"><strong>Số Điện Thoại:</strong> @Model.PhoneNumber</div>
                        <div class="col-md-6"><strong>Địa Chỉ Giao:</strong> @Model.ShippingAddress</div>
                    </div>

                    <h6 class="fw-bold mb-2 pt-2 text-dark">Danh Sách Sản Phẩm</h6>
                    <div class="border-top pt-2">
                        @foreach (var detail in Model.OrderDetails)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2 small">
                                <span class="text-truncate" style="max-width: 300px;">@detail.Product?.Name <span class="text-muted">x@detail.Quantity</span></span>
                                <span class="fw-bold">@detail.Price.ToString("N2") $</span>
                            </div>
                        }
                        <div class="d-flex justify-content-between border-top pt-2 mt-2 fw-bold text-danger fs-5">
                            <span>TỔNG CỘNG:</span>
                            <span>@Model.TotalAmount.ToString("N2") $</span>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-center gap-3">
                    <a class="btn btn-outline-secondary px-4 py-2.5 rounded-pill fw-bold font-13" asp-controller="Profile" asp-action="Index">Xem Lịch Sử</a>
                    <a class="btn btn-primary px-4 py-2.5 rounded-pill fw-bold font-13 shadow" asp-controller="Product" asp-action="Index">Tiếp Tục Mua Sắm</a>
                </div>
            </div>
        </div>
    </div>
</div>
