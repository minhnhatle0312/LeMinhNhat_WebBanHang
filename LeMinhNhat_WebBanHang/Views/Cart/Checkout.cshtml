@model LeMinhNhat_WebBanHang.Models.Order
@{
    ViewData["Title"] = "Thanh Toán Đơn Hàng";
    var cartItems = ViewBag.CartItems as List<LeMinhNhat_WebBanHang.Models.CartItem> ?? new List<LeMinhNhat_WebBanHang.Models.CartItem>();
}

<div class="container py-5">
    <h3 class="fw-bold mb-4"><i class="bi bi-credit-card-2-front me-2 text-primary"></i>Thanh Toán Đơn Hàng</h3>

    <form asp-action="Checkout" method="post">
        <div class="row g-4 animate__animated animate__fadeIn">
            <!-- Delivery details form -->
            <div class="col-12 col-lg-7">
                <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
                    <h5 class="fw-bold mb-4 border-bottom pb-2 text-dark"><i class="bi bi-geo-alt-fill me-2 text-primary"></i>Thông Tin Giao Hàng</h5>

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <!-- PhoneNumber -->
                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-semibold small text-secondary">Số điện thoại liên hệ</label>
                        <input asp-for="PhoneNumber" class="form-control py-2.5 rounded-3" placeholder="Ví dụ: 0912345678" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <!-- ShippingAddress -->
                    <div class="mb-3">
                        <label asp-for="ShippingAddress" class="form-label fw-semibold small text-secondary">Địa chỉ giao hàng chi tiết</label>
                        <input asp-for="ShippingAddress" class="form-control py-2.5 rounded-3" placeholder="Số nhà, Tên đường, Phường, Quận, Thành phố" />
                        <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                    </div>

                    <!-- Notes -->
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label fw-semibold small text-secondary">Ghi chú giao hàng (Không bắt buộc)</label>
                        <textarea asp-for="Notes" class="form-control rounded-3" rows="3" placeholder="Ví dụ: Giao hàng giờ hành chính, gọi trước khi giao..."></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Cart items summary -->
            <div class="col-12 col-lg-5">
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-4">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">Tóm Tắt Đơn Hàng</h5>

                    <div class="checkout-items-list mb-3" style="max-height: 250px; overflow-y: auto;">
                        @foreach (var item in cartItems)
                        {
                            <div class="d-flex align-items-center gap-3 pb-3 mb-3 border-bottom">
                                <img src="@item.ProductImage" alt="@item.ProductName" class="rounded border p-1" style="width: 50px; height: 50px; object-fit: contain;" />
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 fw-bold small text-truncate" style="max-width: 180px;">@item.ProductName</h6>
                                    <span class="text-danger small fw-semibold">@item.Price.ToString("N2") $ <span class="text-muted">x@item.Quantity</span></span>
                                </div>
                                <span class="fw-bold text-dark font-13">@item.TotalPrice.ToString("N2") $</span>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between mb-4 border-top pt-3 fs-5 fw-extrabold text-danger">
                        <span>Tổng thanh toán:</span>
                        <span>@cartItems.Sum(i => i.TotalPrice).ToString("N2") $</span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold shadow">
                        XÁC NHẬN ĐẶT HÀNG
                    </button>
                </div>

                <a class="btn btn-outline-secondary w-100 py-2.5 rounded-3 fw-bold font-13" asp-action="Index">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại giỏ hàng
                </a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
