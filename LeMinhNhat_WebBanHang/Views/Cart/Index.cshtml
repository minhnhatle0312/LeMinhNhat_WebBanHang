@model IEnumerable<LeMinhNhat_WebBanHang.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ Hàng Của Bạn";
    var recommended = ViewBag.RecommendedProducts as List<LeMinhNhat_WebBanHang.Models.Product> ?? new List<LeMinhNhat_WebBanHang.Models.Product>();
}

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h3 class="fw-bold mb-0"><i class="bi bi-cart3 me-2 text-primary"></i>Giỏ Hàng Của Bạn</h3>
        <span class="badge bg-primary rounded-pill px-3 py-2 fs-6 fw-semibold" id="cart-badge-large">@Model.Sum(i => i.Quantity) sản phẩm</span>
    </div>

    <!-- Success message for re-orders or changes -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm p-3 mb-4 animate__animated animate__fadeIn" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                <div>@TempData["Success"]</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4" id="cart-page-container">
        @if (Model != null && Model.Any())
        {
            <!-- List of items -->
            <div class="col-12 col-lg-8 animate__animated animate__fadeInLeft">
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-4">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr class="small text-secondary text-uppercase fw-bold">
                                    <th>Sản Phẩm</th>
                                    <th class="text-center">Giá</th>
                                    <th class="text-center" style="width: 140px;">Số Lượng</th>
                                    <th class="text-end">Tổng</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr id="cart-row-@item.ProductId" class="border-bottom align-middle">
                                        <td>
                                            <div class="d-flex align-items-center gap-3 py-2">
                                                <img src="@item.ProductImage" alt="@item.ProductName" class="rounded border p-1 bg-light shadow-sm" style="width: 70px; height: 70px; object-fit: contain;" />
                                                <div>
                                                    <h6 class="fw-bold mb-1 text-dark" style="max-width: 250px;">@item.ProductName</h6>
                                                    <span class="text-muted small">Mã SP: #@item.ProductId</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center fw-semibold text-dark">$@item.Price.ToString("N2")</td>
                                        <td class="text-center">
                                            <div class="d-inline-flex align-items-center border rounded-pill bg-light p-1">
                                                <button type="button" class="btn btn-sm btn-link text-secondary p-0 px-2 shadow-none border-0" onclick="changeQty(@item.ProductId, -1)">
                                                    <i class="bi bi-minus fs-6"></i>
                                                </button>
                                                <input type="text" id="qty-@item.ProductId" class="form-control form-control-sm border-0 text-center bg-transparent fw-bold shadow-none p-0" style="width: 35px;" value="@item.Quantity" readonly />
                                                <button type="button" class="btn btn-sm btn-link text-secondary p-0 px-2 shadow-none border-0" onclick="changeQty(@item.ProductId, 1)">
                                                    <i class="bi bi-plus fs-6"></i>
                                                </button>
                                            </div>
                                        </td>
                                        <td class="text-end fw-bold text-danger" id="total-@item.ProductId">$@item.TotalPrice.ToString("N2")</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-light border-0 text-muted rounded-circle p-2 shadow-none hover-danger" onclick="removePageItem(@item.ProductId)">
                                                <i class="bi bi-trash fs-5"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <a class="btn btn-outline-secondary py-2.5 px-4 rounded-3 fw-bold font-13 shadow-sm" asp-controller="Product" asp-action="Index">
                    <i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
                </a>
            </div>

            <!-- Summary & Vouchers -->
            <div class="col-12 col-lg-4 animate__animated animate__fadeInRight">
                <!-- Promo Code Panel -->
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-4">
                    <h5 class="fw-bold mb-3 text-dark"><i class="bi bi-ticket-perforated me-2 text-primary"></i>Mã Khuyến Mãi</h5>
                    <p class="text-muted small mb-3">Nhập mã giảm giá của bạn để được áp dụng ưu đãi trực tiếp.</p>
                    <div class="input-group mb-2">
                        <input type="text" id="coupon-code-input" class="form-control rounded-start-3 uppercase py-2.5 shadow-none" placeholder="Ví dụ: GIAM20, WELCOME10" value="@ViewBag.CouponCode" />
                        <button type="button" class="btn btn-primary px-3 rounded-end-3 fw-bold" onclick="applyCouponCode()">Áp Dụng</button>
                    </div>
                    <div id="coupon-alert" class="small mt-1" style="display: none;"></div>
                </div>

                <!-- Invoice Breakdown -->
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                    <h5 class="fw-bold mb-3 border-bottom pb-2 text-dark">Tóm Tắt Đơn Hàng</h5>
                    
                    <div class="d-flex justify-content-between mb-2 small text-secondary">
                        <span>Tiền hàng:</span>
                        <span class="fw-semibold text-dark" id="summary-subtotal">$@Model.Sum(i => i.TotalPrice).ToString("N2")</span>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-2 small text-secondary">
                        <span>Phí vận chuyển:</span>
                        <span class="fw-semibold text-dark" id="summary-shipping">$@(((decimal)ViewBag.ShippingFee).ToString("N2"))</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3 small text-secondary" id="discount-row" style="@(ViewBag.Discount > 0 ? "" : "display: none;")">
                        <span>Giảm giá:</span>
                        <span class="fw-bold text-success" id="summary-discount">-$@(((decimal)ViewBag.Discount).ToString("N2"))</span>
                    </div>

                    <hr class="my-3" />

                    <div class="d-flex justify-content-between mb-4 align-items-center">
                        <span class="fw-bold fs-6 text-dark">Tổng thanh toán:</span>
                        <span class="fw-extrabold fs-4 text-danger" id="summary-total">$@(((decimal)ViewBag.GrandTotal).ToString("N2"))</span>
                    </div>

                    <a class="btn btn-primary w-100 py-3 rounded-3 fw-bold shadow-sm" asp-controller="Cart" asp-action="Checkout">
                        TIẾN HÀNH THANH TOÁN <i class="bi bi-chevron-right ms-1"></i>
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="card border-0 shadow-sm rounded-4 p-5 bg-white d-inline-block animate__animated animate__zoomIn">
                    <i class="bi bi-cart-x display-1 text-muted opacity-25 d-block mb-3"></i>
                    <h4 class="fw-bold text-dark mb-2">Giỏ Hàng Đang Trống</h4>
                    <p class="text-muted mb-4">Bạn chưa chọn mua bất kỳ linh kiện nào từ cửa hàng.</p>
                    <a class="btn btn-primary px-4 py-2.5 rounded-pill shadow-sm fw-bold" asp-controller="Product" asp-action="Index">Mua Sắm Ngay</a>
                </div>
            </div>
        }
    </div>

    <!-- Cross-selling section -->
    @if (recommended.Any())
    {
        <div class="mt-5 pt-3 animate__animated animate__fadeInUp">
            <h4 class="fw-bold text-dark mb-4"><i class="bi bi-heart-fill text-danger me-2"></i>Có Thể Bạn Cũng Thích</h4>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
                @foreach (var prod in recommended)
                {
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card-hover transition bg-white">
                            <div class="p-3 bg-light text-center position-relative">
                                <img src="@(string.IsNullOrEmpty(prod.ImageUrl) ? "/images/no-image.png" : prod.ImageUrl)" alt="@prod.Name" class="img-fluid" style="height: 160px; object-fit: contain;" />
                            </div>
                            <div class="card-body p-3 d-flex flex-column justify-content-between">
                                <div>
                                    <h6 class="fw-bold text-dark text-truncate mb-1">@prod.Name</h6>
                                    <p class="text-muted small text-truncate mb-2" style="max-height: 40px;">@prod.Description</p>
                                </div>
                                <div class="d-flex align-items-center justify-content-between mt-2">
                                    <span class="fw-bold text-danger">$@prod.Price.ToString("N2")</span>
                                    <button class="btn btn-sm btn-primary rounded-circle p-2 d-flex align-items-center justify-content-center border-0 shadow" onclick="quickAddToCart(@prod.Id)" title="Thêm vào giỏ">
                                        <i class="bi bi-plus-lg fs-6"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Apply coupon code via AJAX
        function applyCouponCode() {
            var code = $('#coupon-code-input').val().trim();
            var $alert = $('#coupon-alert');
            
            $.ajax({
                url: '/Cart/ApplyCoupon',
                type: 'POST',
                data: { code: code },
                success: function(data) {
                    if (data.success) {
                        $alert.removeClass('text-danger').addClass('text-success').html('<i class="bi bi-check-circle-fill me-1"></i>' + data.message).show();
                        
                        // Update breakdown
                        updateBreakdown(data.subTotal || parseFloat($('#summary-subtotal').text().replace('$', '').replace(',', '')), data.discount, data.shippingFee, data.grandTotal);
                    } else {
                        $alert.removeClass('text-success').addClass('text-danger').html('<i class="bi bi-exclamation-triangle-fill me-1"></i>' + data.message).show();
                        if (!code) {
                            $alert.hide();
                        }
                    }
                }
            });
        }

        // Helper to update billing values on the DOM
        function updateBreakdown(subtotal, discount, shipping, total) {
            $('#summary-subtotal').text('$' + subtotal.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));
            $('#summary-shipping').text('$' + shipping.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));
            
            if (discount > 0) {
                $('#summary-discount').text('-$' + discount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));
                $('#discount-row').show();
            } else {
                $('#discount-row').hide();
            }
            
            $('#summary-total').text('$' + total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));
        }

        // Increment/Decrement Cart quantity via AJAX
        function changeQty(productId, val) {
            var $input = $('#qty-' + productId);
            var currentVal = parseInt($input.val());
            var newVal = currentVal + val;
            if (newVal <= 0) {
                removePageItem(productId);
                return;
            }

            $.ajax({
                url: '/Cart/UpdateQuantity',
                type: 'POST',
                data: { productId: productId, quantity: newVal },
                success: function(data) {
                    if (data.success) {
                        $input.val(newVal);
                        
                        // Update individual item total
                        $('#total-' + productId).text('$' + data.itemTotal.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));
                        
                        // Update total count badges
                        updateCartBadge(data.totalItems);
                        $('#cart-badge-large').text(data.totalItems + ' sản phẩm');
                        
                        // Update breakdown values
                        updateBreakdown(data.subTotal, data.discount, data.shippingFee, data.grandTotal);
                        
                        if (data.couponCode) {
                            $('#coupon-code-input').val(data.couponCode);
                            $('#coupon-alert').removeClass('text-danger').addClass('text-success').html('<i class="bi bi-check-circle-fill me-1"></i>' + data.couponMessage).show();
                        } else {
                            $('#coupon-alert').hide();
                        }
                    } else {
                        alert(data.message || 'Lỗi khi cập nhật số lượng.');
                    }
                }
            });
        }

        // Remove item from cart via AJAX
        function removePageItem(productId) {
            if (!confirm('Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?')) return;

            $.ajax({
                url: '/Cart/RemoveFromCart',
                type: 'POST',
                data: { productId: productId },
                success: function(data) {
                    if (data.success) {
                        $('#cart-row-' + productId).fadeOut(300, function() {
                            $(this).remove();
                            if (data.totalItems === 0) {
                                // Reload page to show empty cart view
                                location.reload();
                            }
                        });
                        
                        // Update badges
                        updateCartBadge(data.totalItems);
                        $('#cart-badge-large').text(data.totalItems + ' sản phẩm');
                        
                        // Update breakdown
                        updateBreakdown(data.subTotal, data.discount, data.shippingFee, data.grandTotal);
                    } else {
                        alert(data.message || 'Lỗi khi xóa khỏi giỏ.');
                    }
                }
            });
        }

        // Add to cart from recommendations
        function quickAddToCart(productId) {
            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { productId: productId, quantity: 1 },
                success: function(data) {
                    if (data.success) {
                        // Refresh cart page to show new added items
                        location.reload();
                    } else {
                        alert(data.message || 'Lỗi khi thêm vào giỏ.');
                    }
                }
            });
        }

        // Sync main navigation cart badge (defined in layout)
        function updateCartBadge(count) {
            var $badge = $('.nav-link .bi-cart3').siblings('.badge');
            if ($badge.length) {
                if (count > 0) {
                    $badge.text(count).show();
                } else {
                    $badge.hide();
                }
            } else {
                // If badge doesn't exist, create it
                var $cartLink = $('a[href="/Cart"]');
                if ($cartLink.length) {
                    $cartLink.append('<span class="position-absolute top-10 start-95 translate-middle badge rounded-pill bg-danger">' + count + '</span>');
                }
            }
        }
    </script>

    <style>
        .hover-danger:hover {
            background-color: #dc3545 !important;
            color: white !important;
            transform: scale(1.1);
        }
        .product-card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08) !important;
        }
        .transition {
            transition: all 0.3s ease-in-out;
        }
        .uppercase {
            text-transform: uppercase;
        }
    </style>
}
