@model LeMinhNhat_WebBanHang.Models.Category

@{
    ViewData["Title"] = "Xác Nhận Xóa Danh Mục";
}

<div class="container-fluid py-4 px-4" style="background-color: #f8f9fa;">
    <div class="mb-4">
        <h3 class="text-dark fw-bold mb-1 d-flex align-items-center">
            <i class="bi bi-exclamation-diamond-fill text-danger me-2 fs-4"></i> Gỡ Phân Loại Khỏi Cơ Sở Dữ Liệu
        </h3>
        <p class="text-muted small mb-0">Hành động xóa danh mục có thể ảnh hưởng liên đới đến các sản phẩm thuộc danh mục này.</p>
    </div>

    <div class="row">
        <div class="col-12 col-md-9 col-lg-7">

            <div class="alert alert-danger border-0 shadow-sm rounded-4 p-4 mb-4 bg-danger bg-opacity-10 d-flex gap-3 align-items-start">
                <i class="bi bi-shield-fill-exclamation text-danger display-6 style-lh-1"></i>
                <div>
                    <h5 class="fw-bold text-danger mb-1">Cảnh báo cấu trúc hệ thống!</h5>
                    <p class="text-secondary small mb-0">
                        Bạn đang chuẩn bị xóa danh mục <span class="fw-bold text-dark">"@Model.Name"</span> (Mã #@Model.Id). Hãy chắc chắn rằng không còn sản phẩm công nghệ nào trong kho đang liên kết với nhóm ngành này trước khi thực hiện gỡ bỏ.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white mb-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-light-danger border rounded-3 text-danger d-flex align-items-center justify-content-center" style="width: 55px; height: 55px; flex-shrink: 0;">
                            <i class="bi bi-folder-x fs-2"></i>
                        </div>
                        <div>
                            <span class="text-muted small d-block mb-0.5">Tên thực thể bản ghi</span>
                            <h4 class="fw-bold text-dark mb-0">@Model.Name</h4>
                            <small class="text-muted">Định danh Database: Khóa chính cụm #@Model.Id</small>
                        </div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-light border px-4 py-2.5 rounded-2 font-13 text-muted fw-medium">
                        Giữ lại danh mục
                    </a>
                    <button type="submit" class="btn btn-danger px-4 py-2.5 rounded-2 font-13 fw-semibold shadow-sm">
                        <i class="bi bi-trash3-fill me-1"></i> Đồng ý xóa vĩnh viễn
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

<style>
    .style-lh-1 {
        line-height: 1;
    }

    .font-13 {
        font-size: 13px;
    }

    .bg-light-danger {
        background-color: #fdf2f2;
        border: 1px solid #fde8e8;
    }
</style>