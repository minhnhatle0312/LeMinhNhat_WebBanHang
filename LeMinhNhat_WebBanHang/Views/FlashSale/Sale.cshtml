@model List<LeMinhNhat_WebBanHang.Controllers.FlashSaleItem>
@{
    ViewData["Title"] = "Flash Sale - Giá Hời Theo Giờ";
    var saleEndIso = ViewBag.SaleEndTime as string ?? "";
}

<style>
    body { background-color: #020817 !important; }

    .sale-hero-header {
        background: linear-gradient(135deg, #1a0a00 0%, #2d0606 40%, #1a0010 100%);
        border-bottom: 1px solid rgba(239,68,68,0.2);
        padding: 2rem 0;
        position: relative;
        overflow: hidden;
    }

    .sale-hero-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at center, rgba(239,68,68,0.1) 0%, transparent 70%);
        animation: pulse-bg 3s ease-in-out infinite;
    }

    @@keyframes pulse-bg {
        0%, 100% { opacity: 0.5; }
        50% { opacity: 1; }
    }

    .sale-title {
        font-family: 'Outfit', sans-serif;
        font-size: clamp(2rem, 6vw, 3.5rem);
        font-weight: 900;
        background: linear-gradient(135deg, #fbbf24 0%, #ef4444 60%, #ec4899 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Sale countdown bar */
    .sale-countdown-bar {
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.15);
        border-radius: 16px;
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .mini-cd-box {
        text-align: center;
    }

    .mini-cd-num {
        font-size: 2rem;
        font-weight: 900;
        color: #ef4444;
        font-family: 'Outfit', sans-serif;
        line-height: 1;
        display: block;
    }

    .mini-cd-label {
        font-size: 0.6rem;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 700;
    }

    .mini-cd-sep { color: #ef4444; font-size: 1.5rem; font-weight: 900; align-self: flex-start; margin-top: 2px; }

    /* Product cards */
    .sale-section {
        background-color: #020817;
        padding: 3rem 0 5rem;
    }

    .sale-card {
        background: linear-gradient(145deg, #0d1929, #111827);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }

    .sale-card:hover {
        transform: translateY(-8px);
        border-color: rgba(239,68,68,0.4);
        box-shadow: 0 20px 50px rgba(239,68,68,0.15), 0 0 0 1px rgba(239,68,68,0.2);
    }

    .discount-badge {
        position: absolute;
        top: 1rem; right: 1rem;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: #fff;
        font-weight: 900;
        font-size: 0.9rem;
        padding: 6px 14px;
        border-radius: 50px;
        box-shadow: 0 5px 15px rgba(239,68,68,0.4);
        z-index: 2;
    }

    .sale-card-img-wrapper {
        background: linear-gradient(145deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
        padding: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 200px;
        position: relative;
    }

    .sale-card-img-wrapper img {
        max-height: 150px;
        max-width: 100%;
        object-fit: contain;
        filter: drop-shadow(0 10px 25px rgba(0,0,0,0.5));
        transition: transform 0.4s;
    }

    .sale-card:hover .sale-card-img-wrapper img {
        transform: scale(1.06);
    }

    .sale-card-body {
        padding: 1.25rem 1.5rem 1.5rem;
    }

    .sale-product-name {
        color: #f1f5f9;
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 0.75rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
        min-height: 2.8em;
    }

    .price-wrapper { margin-bottom: 1rem; }

    .original-price {
        color: #475569;
        text-decoration: line-through;
        font-size: 0.85rem;
    }

    .sale-price {
        font-size: 1.6rem;
        font-weight: 900;
        color: #ef4444;
        font-family: 'Outfit', sans-serif;
        display: block;
        line-height: 1.1;
    }

    /* Stock progress */
    .stock-label {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
    }

    .stock-text { color: #64748b; font-size: 0.78rem; font-weight: 600; }
    .stock-count { color: #f59e0b; font-size: 0.78rem; font-weight: 700; }

    .stock-bar {
        height: 5px;
        background: rgba(255,255,255,0.07);
        border-radius: 3px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .stock-bar-fill {
        height: 100%;
        border-radius: 3px;
        background: linear-gradient(90deg, #22c55e, #f59e0b);
        transition: width 0.6s ease;
    }

    .stock-bar-fill.low { background: linear-gradient(90deg, #ef4444, #f97316); }

    .buy-btn {
        width: 100%;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
        border: none;
        padding: 0.75rem 1rem;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 800;
        cursor: pointer;
        transition: all 0.3s;
        letter-spacing: 0.02em;
        position: relative;
        overflow: hidden;
    }

    .buy-btn::before {
        content: '';
        position: absolute;
        top: 0; left: -100%;
        width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
        transition: left 0.4s;
    }

    .buy-btn:hover::before { left: 100%; }

    .buy-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(239,68,68,0.4);
    }

    .buy-btn:disabled {
        background: rgba(255,255,255,0.08);
        color: #475569;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .buy-btn:disabled::before { display: none; }

    /* Toast notification */
    .sale-toast {
        position: fixed;
        bottom: 100px;
        right: 25px;
        background: #0d1929;
        border: 1px solid rgba(34,197,94,0.3);
        border-radius: 14px;
        padding: 1rem 1.5rem;
        color: #fff;
        font-size: 0.9rem;
        z-index: 9999;
        display: none;
        max-width: 320px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        animation: slide-in-right 0.4s ease;
    }

    @@keyframes slide-in-right {
        from { transform: translateX(100px); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }

    .sold-out-overlay {
        position: absolute;
        inset: 0;
        background: rgba(2,8,23,0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 20px;
        z-index: 5;
        backdrop-filter: blur(2px);
    }

    .sold-out-label {
        background: rgba(239,68,68,0.15);
        border: 2px solid rgba(239,68,68,0.5);
        color: #ef4444;
        font-weight: 900;
        font-size: 1.2rem;
        letter-spacing: 0.1em;
        padding: 0.5rem 2rem;
        border-radius: 8px;
        transform: rotate(-15deg);
    }

    /* Empty state */
    .empty-sale {
        text-align: center;
        padding: 5rem 2rem;
        color: #475569;
    }
</style>

<!-- Sale Header -->
<div class="sale-hero-header">
    <div class="container px-4 position-relative">
        <div class="row align-items-center g-4">
            <div class="col-12 col-md-7">
                <span class="badge bg-danger text-white px-3 py-1 rounded-pill fw-bold mb-2 d-inline-block" style="letter-spacing:0.1em;">
                    <i class="bi bi-lightning-charge-fill me-1"></i>FLASH SALE ĐANG DIỄN RA
                </span>
                <h1 class="sale-title mb-2">GIÁ HỜI THEO GIỜ</h1>
                <p class="text-muted mb-0" style="max-width: 450px;">
                    Số lượng cực kỳ giới hạn! Giảm giá sốc chỉ trong thời gian ngắn. Mua ngay trước khi hết hàng!
                </p>
            </div>
            <div class="col-12 col-md-5">
                <div class="sale-countdown-bar">
                    <div class="text-center me-2">
                        <p class="text-muted small mb-2 fw-bold" style="letter-spacing:0.08em;">KẾT THÚC SAU</p>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="mini-cd-box">
                            <span class="mini-cd-num" id="sh">00</span>
                            <span class="mini-cd-label">Giờ</span>
                        </div>
                        <span class="mini-cd-sep">:</span>
                        <div class="mini-cd-box">
                            <span class="mini-cd-num" id="sm">00</span>
                            <span class="mini-cd-label">Phút</span>
                        </div>
                        <span class="mini-cd-sep">:</span>
                        <div class="mini-cd-box">
                            <span class="mini-cd-num" id="ss">00</span>
                            <span class="mini-cd-label">Giây</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Flash Sale Product Grid -->
<div class="sale-section">
    <div class="container px-4">
        @if (Model == null || !Model.Any())
        {
            <div class="empty-sale animate__animated animate__fadeIn">
                <i class="bi bi-lightning-charge display-1 opacity-20 d-block mb-3"></i>
                <h4 class="text-white">Flash Sale đã kết thúc</h4>
                <p>Quay lại lần sau để săn giá hời nhé! 🔥</p>
                <a href="/Product/Index" class="btn btn-outline-danger rounded-pill mt-2">Xem Sản Phẩm Thường</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    var stockPct = item.TotalStock > 0 ? (int)((double)item.StockLeft / item.TotalStock * 100) : 0;
                    var isSoldOut = item.StockLeft <= 0;
                    <div class="col-12 col-sm-6 col-xl-3 animate__animated animate__fadeInUp" id="card-@item.ProductId">
                        <div class="sale-card h-100 position-relative">
                            @if (isSoldOut)
                            {
                                <div class="sold-out-overlay">
                                    <span class="sold-out-label">HẾT HÀNG</span>
                                </div>
                            }

                            <div class="discount-badge">-@item.DiscountPercent%</div>

                            <div class="sale-card-img-wrapper">
                                <img src="@item.ImageUrl" alt="@item.ProductName" />
                            </div>

                            <div class="sale-card-body">
                                <div class="sale-product-name">@item.ProductName</div>

                                <div class="price-wrapper">
                                    <span class="original-price">@item.OriginalPrice.ToString("N2") $</span>
                                    <span class="sale-price">@item.SalePrice.ToString("N2") $</span>
                                </div>

                                <div class="stock-label">
                                    <span class="stock-text">Đã bán @(item.TotalStock - item.StockLeft)/@item.TotalStock</span>
                                    <span class="stock-count" id="stock-text-@item.ProductId">
                                        @(isSoldOut ? "Hết hàng!" : $"Còn {item.StockLeft}")
                                    </span>
                                </div>
                                <div class="stock-bar">
                                    <div class="stock-bar-fill @(stockPct <= 30 ? "low" : "")"
                                         id="stock-bar-@item.ProductId"
                                         style="width: @stockPct%"></div>
                                </div>

                                <button class="buy-btn"
                                        id="buy-btn-@item.ProductId"
                                        onclick="flashBuy(@item.ProductId)"
                                        @(isSoldOut ? "disabled" : "")>
                                    <i class="bi bi-lightning-charge-fill me-2"></i>
                                    @(isSoldOut ? "HẾT HÀNG" : "MUA NGAY")
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-5">
                <a href="/Product/Index" class="btn btn-outline-secondary rounded-pill px-5 py-2 text-muted">
                    <i class="bi bi-grid me-2"></i>Xem Tất Cả Sản Phẩm
                </a>
            </div>
        }
    </div>
</div>

<!-- Toast notification -->
<div class="sale-toast" id="sale-toast">
    <div class="d-flex align-items-center gap-2 mb-1">
        <i class="bi bi-check-circle-fill text-success"></i>
        <strong id="toast-title">Thành công!</strong>
    </div>
    <div id="toast-msg" class="text-muted small">Đã thêm vào giỏ hàng Flash Sale.</div>
</div>

@section Scripts {
<script>
    var saleEndTime = new Date('@Html.Raw(saleEndIso)');

    function updateSaleCountdown() {
        var now = new Date();
        var diff = Math.max(0, Math.floor((saleEndTime - now) / 1000));
        var h = Math.floor(diff / 3600);
        var m = Math.floor((diff % 3600) / 60);
        var s = diff % 60;
        document.getElementById('sh').textContent = String(h).padStart(2,'0');
        document.getElementById('sm').textContent = String(m).padStart(2,'0');
        document.getElementById('ss').textContent = String(s).padStart(2,'0');
    }

    setInterval(updateSaleCountdown, 1000);
    updateSaleCountdown();

    function showToast(title, msg, isSuccess) {
        var $toast = document.getElementById('sale-toast');
        document.getElementById('toast-title').textContent = title;
        document.getElementById('toast-msg').textContent = msg;
        $toast.style.borderColor = isSuccess ? 'rgba(34,197,94,0.3)' : 'rgba(239,68,68,0.3)';
        $toast.style.display = 'block';
        setTimeout(function() { $toast.style.display = 'none'; }, 3500);
    }

    function flashBuy(productId) {
        var btn = document.getElementById('buy-btn-' + productId);
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';

        $.ajax({
            url: '/FlashSale/BuyNow',
            type: 'POST',
            data: { productId: productId },
            success: function(data) {
                if (data.success) {
                    // Also add to the main cart
                    addToCart(productId, 1);

                    // Update stock display
                    var stockLeft = data.stockLeft;
                    document.getElementById('stock-text-' + productId).textContent = stockLeft > 0 ? 'Còn ' + stockLeft : 'Hết hàng!';

                    // Update stock bar
                    var card = document.getElementById('card-' + productId);
                    var bar = document.getElementById('stock-bar-' + productId);
                    if (bar) {
                        // Approximate percentage
                        var pct = Math.max(0, parseInt(bar.style.width) - 20);
                        bar.style.width = pct + '%';
                        if (pct <= 30) bar.classList.add('low');
                    }

                    if (stockLeft <= 0) {
                        btn.innerHTML = 'HẾT HÀNG';
                        showToast('Vừa kịp! 🔥', data.message, true);
                    } else {
                        btn.disabled = false;
                        btn.innerHTML = '<i class="bi bi-lightning-charge-fill me-2"></i>MUA NGAY';
                        showToast('Thành công! 🎉', data.message, true);
                    }
                } else {
                    btn.innerHTML = 'HẾT HÀNG';
                    showToast('Ôi không! 😢', data.message, false);
                }
            },
            error: function() {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-lightning-charge-fill me-2"></i>MUA NGAY';
                showToast('Lỗi', 'Đã xảy ra lỗi. Vui lòng thử lại.', false);
            }
        });
    }
</script>
}
