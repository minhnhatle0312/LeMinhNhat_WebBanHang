@model LeMinhNhat_WebBanHang.Models.Product

@{
    ViewData["Title"] = "Cập Nhật Sản Phẩm";
}

<div class="container py-4">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-light border btn-sm rounded-pill text-muted px-3">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom-smooth">
            <h4 class="card-title mb-0 text-info fw-semibold d-flex align-items-center">
                <i class="bi bi-pencil-square me-2"></i> Chỉnh Sửa Thông Tin Sản Phẩm
            </h4>
        </div>

        <div class="card-body p-4 bg-light-curve">
            <form asp-action="Update" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                <input type="hidden" asp-for="Id" />

                <div class="row g-4">
                    <div class="col-lg-7">
                        <div class="p-3 bg-white rounded-3 shadow-xs border">
                            <h6 class="text-secondary border-bottom pb-2 mb-3 fw-bold">
                                <i class="bi bi-sliders me-1"></i> Thông tin điều chỉnh
                            </h6>

                            <div class="form-group mb-3">
                                <label asp-for="Name" class="form-label fw-semibold text-dark">Tên sản phẩm <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-type"></i></span>
                                    <input asp-for="Name" class="form-control border-start-0 ps-1" placeholder="Nhập tên sản phẩm mới" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Price" class="form-label fw-semibold text-dark">Giá điều chỉnh ($) <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-currency-dollar"></i></span>
                                        <input asp-for="Price" class="form-control border-start-0 ps-1" type="number" step="0.01" />
                                    </div>
                                    <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="CategoryId" class="form-label fw-semibold text-dark">Danh mục phân loại <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-grid-fill"></i></span>
                                        <select asp-for="CategoryId" class="form-select border-start-0 ps-1" asp-items="ViewBag.Categories">
                                            <option value="">-- Chọn danh mục --</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <div class="form-group mb-2">
                                <label asp-for="Description" class="form-label fw-semibold text-dark">Mô tả sản phẩm</label>
                                <textarea asp-for="Description" class="form-control" rows="5" placeholder="Cập nhật lại mô tả chi tiết thông số..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="p-3 bg-white rounded-3 shadow-xs border h-100">
                            <h6 class="text-secondary border-bottom pb-2 mb-3 fw-bold">
                                <i class="bi bi-image-fill me-1"></i> Hình ảnh & Lưu trữ
                            </h6>

                            <div class="mb-4">
                                <label class="form-label fw-semibold text-dark">Ảnh đại diện chính</label>
                                <input type="file" name="imageUrl" class="form-control mb-2" accept="image/*" onchange="previewUpdateImage(this)" />

                                <div class="bg-light rounded p-3 border border-dashed text-center d-flex flex-column align-items-center justify-content-center" style="min-height: 140px;">
                                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                    {
                                        <small class="text-muted mb-1 d-block" id="img-status-label">Ảnh hiện tại trên hệ thống:</small>
                                        <img id="update-preview" src="@Model.ImageUrl" alt="Product Image" class="img-fluid rounded border shadow-sm" style="max-height: 100px; object-fit: contain;" />
                                    }
                                    else
                                    {
                                        <small class="text-muted mb-1 d-block" id="img-status-label">Chưa có ảnh đại diện:</small>
                                        <img id="update-preview" src="#" alt="Preview" class="img-fluid rounded border shadow-sm d-none" style="max-height: 100px; object-fit: contain;" />
                                        <div id="update-placeholder" class="text-muted small"><i class="bi bi-card-image fs-3 d-block mb-1"></i>Trống</div>
                                    }
                                </div>
                            </div>

                            <div class="mb-2">
                                <label class="form-label fw-semibold text-dark">Tải thêm ảnh mô tả phụ</label>
                                <input type="file" name="imageUrls" class="form-control" accept="image/*" multiple />
                                <div class="mt-2 p-2 bg-light rounded text-muted small border">
                                    <i class="bi bi-info-circle me-1"></i> Tải lên các file mới tại đây nếu bạn muốn bổ sung thêm góc nhìn chi tiết cho sản phẩm.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">
                        Hủy điều chỉnh
                    </a>
                    <button type="submit" class="btn btn-info text-white px-4 rounded-pill shadow-sm fw-semibold">
                        <i class="bi bi-check-lg me-1"></i> Cập nhật ngay
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewUpdateImage(input) {
            var preview = document.getElementById('update-preview');
            var placeholder = document.getElementById('update-placeholder');
            var label = document.getElementById('img-status-label');

            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');
                    if (placeholder) placeholder.classList.add('d-none');
                    label.innerText = "Ảnh mới chuẩn bị thay thế:";
                    label.classList.remove('text-muted');
                    label.classList.add('text-success', 'fw-semibold');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}