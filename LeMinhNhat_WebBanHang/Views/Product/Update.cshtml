@model LeMinhNhat_WebBanHang.Models.Product

@{
    ViewData["Title"] = "Chỉnh Sửa Sản Phẩm";
}

<div class="container-fluid py-2">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h3 class="text-dark fw-bold mb-1 d-flex align-items-center">
                <i class="bi bi-pencil-square text-info me-2 fs-4"></i> Hiệu Chỉnh Thiết Bị
            </h3>
            <p class="text-muted small mb-0">Cập nhật lại giá cả, cấu hình hoặc phân loại cho mã hàng #@Model.Id.</p>
        </div>
        <a asp-action="Index" class="btn btn-white border btn-sm px-3 rounded-2 text-muted fw-medium">
            <i class="bi bi-arrow-left me-1"></i> Trở về kho hàng
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white">
        <div class="card-body p-4 p-lg-5">
            <form asp-action="Update" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />

                <div class="row g-4">
                    <div class="col-12 col-lg-7">
                        <h5 class="fw-bold text-dark border-start border-3 border-info ps-2 mb-4">Nội dung thay đổi</h5>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold text-secondary small">Tên thiết bị linh kiện</label>
                            <div class="input-group border rounded-3 bg-light">
                                <span class="input-group-text bg-transparent border-0 text-muted"><i class="bi bi-box-seam-fill"></i></span>
                                <input asp-for="Name" class="form-control border-0 bg-transparent py-2.5 shadow-none fw-semibold text-dark" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-12 col-sm-6">
                                <label asp-for="Price" class="form-label fw-semibold text-secondary small">Giá bán hiện hành ($)</label>
                                <div class="input-group border rounded-3 bg-light">
                                    <span class="input-group-text bg-transparent border-0 text-muted"><i class="bi bi-tags-fill"></i></span>
                                    <input asp-for="Price" class="form-control border-0 bg-transparent py-2.5 shadow-none text-danger fw-bold" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-12 col-sm-6">
                                <label asp-for="CategoryId" class="form-label fw-semibold text-secondary small">Thuộc nhóm ngành phân loại</label>
                                <div class="input-group border rounded-3 bg-light">
                                    <span class="input-group-text bg-transparent border-0 text-muted"><i class="bi bi-bookmark-star-fill"></i></span>
                                    <select asp-for="CategoryId" class="form-select border-0 bg-transparent py-2.5 shadow-none text-dark font-12" asp-items="ViewBag.Categories"></select>
                                </div>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold text-secondary small">Cập nhật đặc tính chi tiết</label>
                            <textarea asp-for="Description" class="form-control border rounded-3 p-3 shadow-none lh-lg text-muted" rows="5" style="background-color: #fafafa;"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-12 col-lg-5 ps-lg-4 border-start-lg">
                        <h5 class="fw-bold text-dark border-start border-3 border-secondary ps-2 mb-4">Hình ảnh gốc hệ thống</h5>

                        <div class="row align-items-center mb-4 p-3 rounded-3 g-2 bg-light-soft">
                            <div class="col-5 text-center">
                                <div class="bg-white border rounded-2 p-1 d-flex align-items-center justify-content-center mx-auto" style="width: 100px; height: 100px;">
                                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                    {
                                        <img src="@Model.ImageUrl" class="w-100 h-100 object-fit-contain rounded-1" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-image text-black-30 fs-2"></i>
                                    }
                                </div>
                                <span class="text-muted d-block font-11 mt-1">Ảnh hiện tại</span>
                            </div>

                            <div class="col-2 text-center text-muted">
                                <i class="bi bi-chevron-right fs-4"></i>
                            </div>

                            <div class="col-5 text-center">
                                <div class="bg-white border rounded-2 p-1 d-flex align-items-center justify-content-center mx-auto" style="width: 100px; height: 100px;">
                                    <img id="update-preview" src="#" class="w-100 h-100 object-fit-contain rounded-1 d-none" />
                                    <div id="update-placeholder" class="text-black-30 font-10 px-1 text-center">
                                        <i class="bi bi-image-fill fs-3 d-block mb-1"></i>Chưa đổi
                                    </div>
                                </div>
                                <span id="img-status-label" class="text-muted d-block font-11 mt-1">Ảnh thay thế</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold text-secondary small">Tải lên tập tin ảnh mới</label>
                            <input type="file" name="imageUrl" class="form-control border rounded-3 bg-light py-2 shadow-none font-12" accept="image/*" onchange="previewUpdateImage(this)" />
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light border px-4 py-2.5 rounded-2 font-12 fw-medium text-muted">
                        Hủy thay đổi
                    </a>
                    <button type="submit" class="btn btn-info text-white px-4 py-2.5 rounded-2 font-12 fw-semibold shadow-sm">
                        <i class="bi bi-check-circle-fill me-1"></i> Lưu & Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .btn-white {
        background: #fff;
    }

    .bg-light-soft {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
    }

    @@media (min-width: 992px) {
        .border-start-lg {
            border-start: 1px solid #e2e8f0;
        }
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function previewUpdateImage(input) {
            var preview = document.getElementById('update-preview');
            var placeholder = document.getElementById('update-placeholder');
            var label = document.getElementById('img-status-label');

            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');
                    if (placeholder) placeholder.classList.add('d-none');
                    label.innerText = "Sẵn sàng thay!";
                    label.className = "text-success d-block font-11 mt-1 fw-semibold";
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}