@model LeMinhNhat_WebBanHang.Models.Product

@{
    ViewData["Title"] = "Chi Tiết Sản Phẩm - " + Model.Name;
}

<div class="container py-4">
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-light border btn-sm rounded-pill text-muted px-3">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
        <div>
            <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-outline-info btn-sm rounded-pill px-3 me-2">
                <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-body p-4 p-lg-5 bg-white">
            <div class="row g-5">

                <div class="col-lg-5">
                    <div class="main-image-container border rounded-3 p-3 bg-light text-center mb-3 d-flex align-items-center justify-content-center" style="min-height: 350px;">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img id="current-main-img" src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded transition-zoom" style="max-height: 320px; object-fit: contain;" />
                        }
                        else
                        {
                            <div class="text-muted text-center">
                                <i class="bi bi-image d-block display-4 mb-2 text-black-50"></i>
                                <span>Sản phẩm chưa có ảnh đại diện</span>
                            </div>
                        }
                    </div>

                    @if (Model.ImageUrls != null && Model.ImageUrls.Count > 0)
                    {
                        <div class="sub-images-gallery mt-2">
                            <h6 class="text-muted small fw-semibold mb-2"><i class="bi bi-images me-1"></i> Bộ sưu tập góc nhìn (@Model.ImageUrls.Count)</h6>
                            <div class="d-flex flex-wrap gap-2">
                                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <div class="thumb-img-wrapper border rounded active-thumb" onclick="changeMainImage('@Model.ImageUrl', this)" style="width: 70px; height: 70px; cursor: pointer; overflow: hidden; background: #fff;">
                                        <img src="@Model.ImageUrl" class="w-100 h-100 p-1" style="object-fit: contain;" />
                                    </div>
                                }
                                @foreach (var imgUrl in Model.ImageUrls)
                                {
                                    <div class="thumb-img-wrapper border rounded" onclick="changeMainImage('@imgUrl', this)" style="width: 70px; height: 70px; cursor: pointer; overflow: hidden; background: #fff;">
                                        <img src="@imgUrl" class="w-100 h-100 p-1" style="object-fit: contain;" />
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="col-lg-7 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge bg-light text-secondary border px-2 py-1 small fw-normal">ID: #@Model.Id</span>
                            <span class="badge bg-primary-soft text-primary px-2 py-1 fw-semibold">
                                <i class="bi bi-grid-1x2 me-1"></i> Danh mục ID: @Model.CategoryId
                            </span>
                        </div>

                        <h2 class="text-dark fw-bold mb-3">@Model.Name</h2>

                        <div class="price-box bg-light p-3 rounded-3 mb-4 d-inline-block border-start border-primary border-4">
                            <span class="text-muted small d-block mb-1">Giá niêm yết công khai</span>
                            <span class="text-primary fs-3 fw-bold">@Model.Price.ToString("N2") $</span>
                        </div>

                        <div class="description-block mb-4">
                            <h5 class="text-dark fw-semibold mb-2 border-bottom pb-2">
                                <i class="bi bi-file-earmark-text me-1"></i> Thông số & Mô tả cấu hình
                            </h5>
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <p class="text-secondary lh-lg mb-0 text-justify" style="white-space: pre-line;">@Model.Description</p>
                            }
                            else
                            {
                                <p class="text-muted fst-italic mb-0">Sản phẩm này hiện chưa được cập nhật thông số kỹ thuật chi tiết từ nhà sản xuất.</p>
                            }
                        </div>
                    </div>

                    <div class="action-footer pt-3 border-top mt-4 d-flex gap-2">
                        <button class="btn btn-primary px-4 py-2 rounded-pill shadow-sm flex-grow-1 flex-md-grow-0">
                            <i class="bi bi-cart-plus me-2"></i> Thêm vào giỏ hàng
                        </button>
                        <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-light border px-4 py-2 rounded-pill">
                            <i class="bi bi-gear me-1"></i> Quản trị tệp
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeMainImage(src, element) {
            // Thay đổi thuộc tính đường dẫn của ảnh chính
            document.getElementById('current-main-img').src = src;

            // Xóa class active ở tất cả các khung ảnh thu nhỏ
            var thumbs = document.querySelectorAll('.thumb-img-wrapper');
            thumbs.forEach(function (thumb) {
                thumb.classList.remove('border-primary', 'active-thumb');
                thumb.style.borderColor = '#dee2e6';
            });

            // Thêm hiệu ứng viền xanh cho ảnh đang được click chọn
            element.classList.add('border-primary', 'active-thumb');
            element.style.borderColor = '#0d6efd';
        }
    </script>

    <style>
        .bg-primary-soft {
            background-color: #f0f6ff;
        }

        .active-thumb {
            border-width: 2px !important;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
        }

        .transition-zoom {
            transition: transform 0.3s ease;
        }

        .main-image-container:hover .transition-zoom {
            transform: scale(1.03);
        }

        .text-justify {
            text-align: justify;
        }
    </style>
}