@model IEnumerable<LeMinhNhat_WebBanHang.Models.Product>

@{
    ViewData["Title"] = "Bảng Điều Khiển Quản Lý Sản Phẩm";
}

<div class="container-fluid py-4 px-4" style="background-color: #f8f9fa;">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="text-dark fw-bold mb-1 d-flex align-items-center">
                <i class="bi bi-grid-3x3-gap-fill text-primary me-2 fs-3"></i> Hệ Thống Quản Lý Sản Phẩm
            </h2>
            <p class="text-muted mb-0">Hệ thống phân tích, cập nhật thông tin và điều chỉnh giá hàng hóa real-time.</p>
        </div>
        <div>
            <a asp-action="Add" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm fw-semibold transition-all">
                <i class="bi bi-plus-circle-fill me-2"></i> Thêm sản phẩm mới
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-3 p-3 bg-white h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-muted small fw-semibold d-block mb-1">TỔNG SẢN PHẨM</span>
                        <h3 class="fw-bold text-dark mb-0">@Model.Count()</h3>
                    </div>
                    <div class="bg-primary-soft p-3 rounded-3 text-primary">
                        <i class="bi bi-box-seam fs-4 d-block"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-3 p-3 bg-white h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-muted small fw-semibold d-block mb-1">GIÁ CAO NHẤT</span>
                        <h3 class="fw-bold text-success mb-0">
                            @(Model.Any() ? Model.Max(p => p.Price).ToString("N0") : "0") <span class="fs-6 fw-normal">đ</span>
                        </h3>
                    </div>
                    <div class="bg-success-soft p-3 rounded-3 text-success">
                        <i class="bi bi-graph-up-arrow fs-4 d-block"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden bg-white">

        <div class="card-header bg-white py-3 border-bottom border-light">
            <div class="row g-3 align-items-center">
                <div class="col-12 col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-search"></i></span>
                        <input type="text" id="tableSearchInput" class="form-control border-start-0 bg-light-focus" placeholder="Tìm kiếm nhanh sản phẩm..." />
                    </div>
                </div>
                <div class="col-12 col-md-8 text-md-end text-muted small">
                    <i class="bi bi-info-circle me-1"></i> Bấm vào tiêu đề bảng để sắp xếp | Di chuột vào hành động để xem chi tiết
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="productTable">
                <thead class="bg-light-smooth text-secondary border-bottom">
                    <tr>
                        <th scope="col" class="ps-4 text-center" style="width: 80px;">Mã số</th>
                        <th scope="col" style="width: 100px;">Hình ảnh</th>
                        <th scope="col">Tên mặt hàng sản phẩm</th>
                        <th scope="col" style="width: 160px;">Giá bán công khai</th>
                        <th scope="col" class="d-none d-lg-table-cell" style="max-width: 300px;">Mô tả kỹ thuật</th>
                        <th scope="col" class="text-center" style="width: 120px;">Danh mục</th>
                        <th scope="col" class="text-end pe-4" style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-center fw-semibold text-muted">
                                #@Html.DisplayFor(modelItem => item.Id)
                            </td>

                            <td>
                                <div class="product-thumb-frame border rounded-3 bg-light d-flex align-items-center justify-content-center overflow-hidden shadow-xs" style="width: 64px; height: 64px;">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Name" class="w-100 h-100 object-fit-cover transition-img" />
                                    }
                                    else
                                    {
                                        <div class="text-black-30 d-flex flex-column align-items-center">
                                            <i class="bi bi-image fs-5 line-height-1"></i>
                                            <span style="font-size: 8px;" class="fw-medium text-uppercase text-muted mt-1">No Image</span>
                                        </div>
                                    }
                                </div>
                            </td>

                            <td>
                                <div class="fw-bold text-dark mb-0 text-truncate-1">@item.Name</div>
                                <span class="badge bg-light text-dark border rounded-pill px-2 py-0.5 mt-1" style="font-size: 10px;">
                                    <i class="bi bi-tag-fill text-secondary me-1"></i>Hàng chính hãng
                                </span>
                            </td>

                            <td>
                                <span class="fw-bold text-primary fs-6">
                                    @item.Price.ToString("N2") <span class="small fw-normal text-secondary">$</span>
                                </span>
                            </td>

                            <td class="d-none d-lg-table-cell text-muted text-truncate-2 small">
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    @item.Description
                                }
                                else
                                {
                                    <span class="text-black-30 fst-italic">Chưa có thông số dữ liệu...</span>
                                }
                            </td>

                            <td class="text-center">
                                <span class="badge bg-info-soft text-info rounded px-3 py-1.5 fw-semibold border border-info-subtle">
                                    Mã: @item.CategoryId
                                </span>
                            </td>

                            <td class="text-end pe-4">
                                <div class="d-inline-flex gap-1">
                                    <a asp-action="Display" asp-route-id="@item.Id" class="btn btn-icon-action btn-outline-primary" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-icon-action btn-outline-info" title="Sửa thông tin">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-icon-action btn-outline-danger" title="Xóa mặt hàng">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox display-4 d-block mb-2 text-black-30"></i>
                                Kho hàng hiện tại trống. Hãy bấm nút "Thêm sản phẩm mới" để bắt đầu!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('tableSearchInput').addEventListener('keyup', function () {
            var value = this.value.toLowerCase().trim();
            var rows = document.querySelectorAll('#productTable tbody tr');

            rows.forEach(function (row) {
                // Kiểm tra xem hàng đó có chứa dữ liệu rỗng không
                if (row.cells.length > 1) {
                    var productName = row.cells[2].textContent.toLowerCase();
                    var productId = row.cells[0].textContent.toLowerCase();
                    var productDesc = row.cells[4].textContent.toLowerCase();

                    if (productName.includes(value) || productId.includes(value) || productDesc.includes(value)) {
                        row.style.display = "";
                    } else {
                        row.style.display = "none";
                    }
                }
            });
        });
    </script>

    <style>
        /* Khung mềm cho khối */
        .bg-primary-soft {
            background-color: #eef5ff;
        }

        .bg-success-soft {
            background-color: #e8f9ee;
        }

        .bg-info-soft {
            background-color: #e6f9ff;
        }

        .bg-light-smooth {
            background-color: #fcfdfe;
        }

        .text-black-30 {
            color: #bcbcbc;
        }

        /* Hiệu ứng cắt chữ thông minh */
        .text-truncate-1 {
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .text-truncate-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        /* Tương tác ảnh */
        .object-fit-cover {
            object-fit: cover;
        }

        .transition-img {
            transition: transform 0.2s ease;
        }

        .product-thumb-frame:hover .transition-img {
            transform: scale(1.1);
        }

        /* Nút icon hành động hình tròn thanh lịch */
        .btn-icon-action {
            width: 32px;
            height: 32px;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 14px;
            transition: all 0.2s ease;
            background: transparent;
        }

            .btn-icon-action:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 6px rgba(0,0,0,0.08);
            }

        /* Focus input mịn */
        .bg-light-focus:focus {
            background-color: #fff !important;
            border-color: #86b7fe !important;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25) !important;
        }

        .transition-all {
            transition: all 0.2s ease;
        }

            .transition-all:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(13,110,253,0.2) !important;
            }
    </style>
}