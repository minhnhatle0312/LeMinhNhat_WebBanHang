
@{
    ViewData["Title"] = "Thế Giới Công Nghệ & Điện Máy Chính Hãng";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<div class="dmx-mega-wrapper py-4" style="background-color: #f0f2f5; font-family: system-ui, -apple-system, sans-serif;">
    <div class="container-fluid px-lg-5">

        <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm border-start border-4 border-dmx">
            <div>
                <span class="badge bg-danger text-white fw-bold px-2.5 py-1 mb-1 animate__animated animate__flash animate__infinite animate__slower font-10">LIVE CONSOLE</span>
                <h5 class="text-dark fw-black mb-0 d-flex align-items-center font-16">
                    <i class="bi bi-cpu-fill text-dmx me-2 animate__animated animate__pulse animate__infinite"></i> CƠ SỞ DỮ LIỆU KHO HÀNG ĐIỆN MÁY
                </h5>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <a asp-area="Admin" asp-controller="ProductManager" asp-action="Add" class="btn btn-dmx-gradient px-4 py-2.5 rounded-3 fw-bold shadow-sm font-13 position-relative overflow-hidden btn-shine">
                    <i class="bi bi-plus-circle-fill me-2"></i> ĐĂNG KÝ SẢN PHẨM MỚI
                </a>
            }
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-xl-8">
                <div id="dmxPremiumCarousel" class="carousel slide carousel-fade shadow-sm rounded-4 overflow-hidden h-100" data-bs-ride="carousel">
                    <div class="carousel-indicators mb-3">
                        <button type="button" data-bs-target="#dmxPremiumCarousel" data-bs-slide-to="0" class="active rounded-circle" style="width: 10px; height: 10px;"></button>
                        <button type="button" data-bs-target="#dmxPremiumCarousel" data-bs-slide-to="1" class="rounded-circle" style="width: 10px; height: 10px;"></button>
                        <button type="button" data-bs-target="#dmxPremiumCarousel" data-bs-slide-to="2" class="rounded-circle" style="width: 10px; height: 10px;"></button>
                    </div>

                    <div class="carousel-inner h-100">
                        <div class="carousel-item active h-100" data-bs-interval="4000">
                            <div class="mega-banner-slide p-5 text-white d-flex flex-column justify-content-center position-relative h-100" style="background: linear-gradient(135deg, #005691 0%, #00a8ff 100%); min-height: 380px;">
                                <div class="banner-overlay-particles"></div>
                                <div class="position-relative z-3 col-10 col-md-7 animate__animated animate__fadeInLeft">
                                    <span class="badge bg-warning text-dark rounded-pill px-3 py-1.5 fw-bold mb-3 font-11 shadow">SIÊU PHẨM GIÁ SỐC</span>
                                    <h1 class="fw-black display-5 mb-2 style-tracking-tight">SMARTPHONE CAO CẤP <br><span class="text-warning">GIẢM 5 TRỆU ĐỒNG</span></h1>
                                    <p class="mb-4 opacity-90 font-14">Hỗ trợ đặc quyền thu cũ đổi mới - Tặng thêm bộ sạc siêu tốc 45W chính hãng.</p>
                                    <a href="#product-showcase" class="btn btn-light text-dmx fw-bold px-4 py-2.5 rounded-pill shadow action-pulse">Săn Ngay Deal Hot</a>
                                </div>
                                <div class="slide-floating-asset d-none d-md-block position-absolute end-0 bottom-0 mb-4 me-5 animate__animated animate__fadeInRight">
                                    <i class="bi bi-phone text-white opacity-20" style="font-size: 16rem; line-height: 1;"></i>
                                </div>
                            </div>
                        </div>

                        <div class="carousel-item h-100" data-bs-interval="4000">
                            <div class="mega-banner-slide p-5 text-white d-flex flex-column justify-content-center position-relative h-100" style="background: linear-gradient(135deg, #d63031 0%, #e84393 100%); min-height: 380px;">
                                <div class="position-relative z-3 col-10 col-md-7 animate__animated animate__fadeInDown">
                                    <span class="badge bg-white text-danger rounded-pill px-3 py-1.5 fw-bold mb-3 font-11 shadow">MÙA TỰU TRƯỜNG</span>
                                    <h1 class="fw-black display-5 mb-2 style-tracking-tight">LAPTOP ĐỒ HỌA/GAMING <br><span class="text-light">TẶNG PHIẾU 2.000.000đ</span></h1>
                                    <p class="mb-4 opacity-90 font-14">Giảm thêm 5% cho sinh viên HUTECH. Tặng kèm chuột không dây và Balo sành điệu.</p>
                                    <a href="#product-showcase" class="btn btn-warning text-dark fw-bold px-4 py-2.5 rounded-pill shadow">Xem Ngay Danh Sách</a>
                                </div>
                                <div class="slide-floating-asset d-none d-md-block position-absolute end-0 bottom-0 mb-4 me-5">
                                    <i class="bi bi-laptop text-white opacity-10" style="font-size: 16rem; line-height: 1;"></i>
                                </div>
                            </div>
                        </div>

                        <div class="carousel-item h-100" data-bs-interval="4000">
                            <div class="mega-banner-slide p-5 text-white d-flex flex-column justify-content-center position-relative h-100" style="background: linear-gradient(135deg, #00b894 0%, #00cec9 100%); min-height: 380px;">
                                <div class="position-relative z-3 col-10 col-md-7 animate__animated animate__zoomIn">
                                    <span class="badge bg-dark text-warning rounded-pill px-3 py-1.5 fw-bold mb-3 font-11 shadow">GIÁ RẺ QUÁ</span>
                                    <h1 class="fw-black display-5 mb-2 style-tracking-tight">PHỤ KIỆN ĐỒNG GIÁ <br><span class="text-warning">CHỈ TỪ 99.000đ</span></h1>
                                    <p class="mb-4 opacity-90 font-14">Tai nghe Bluetooth, Pin sạc dự phòng, Cáp sạc nhanh mua 1 tặng 1 cực sốc.</p>
                                    <a href="#product-showcase" class="btn btn-dark text-white fw-bold px-4 py-2.5 rounded-pill shadow">Khám Phá Ưu Đãi</a>
                                </div>
                                <div class="slide-floating-asset d-none d-md-block position-absolute end-0 bottom-0 mb-4 me-5">
                                    <i class="bi bi-earbuds text-white opacity-10" style="font-size: 16rem; line-height: 1;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-4 d-flex flex-column gap-3">
                <div class="sub-banner-box rounded-4 overflow-hidden position-relative flex-grow-1 p-4 text-white d-flex align-items-center" style="background: linear-gradient(45deg, #fe8c00, #f857a6); min-height: 182px;">
                    <div class="z-3 position-relative">
                        <span class="badge bg-dark font-9 mb-1">MÃ: DMX500K</span>
                        <h5 class="fw-black mb-1 font-16">XẢ KHO PHỤ KIỆN</h5>
                        <p class="small mb-2 opacity-90 font-12">Giảm trực tiếp 500k khi <br>mua gói combo 3 món.</p>
                        <span class="btn btn-white-mini font-11 fw-bold px-3 py-1.5 rounded-pill shadow-sm">Lấy Mã Ngay</span>
                    </div>
                    <i class="bi bi-smartwatch position-absolute end-0 bottom-0 opacity-15 font-96 mb-n3 me-2"></i>
                </div>

                <div class="sub-banner-box rounded-4 overflow-hidden position-relative flex-grow-1 p-4 text-white d-flex align-items-center" style="background: linear-gradient(45deg, #00c6ff, #0072ff); min-height: 182px;">
                    <div class="z-3 position-relative">
                        <span class="badge bg-danger font-9 mb-1">TRẢ GÓP 0%</span>
                        <h5 class="fw-black mb-1 font-16">ĐẶC QUYỀN LAPTOP</h5>
                        <p class="small mb-2 opacity-90 font-12">Không cần trả trước - Nhận máy <br>ngay sau 5 phút xét duyệt.</p>
                        <span class="btn btn-white-mini font-11 fw-bold px-3 py-1.5 rounded-pill shadow-sm">Đăng Ký Thử</span>
                    </div>
                    <i class="bi bi-cpu position-absolute end-0 bottom-0 opacity-15 font-96 mb-n3 me-2"></i>
                </div>
            </div>
        </div>

        <div class="row g-4" id="product-showcase">

            <div class="col-12 col-lg-4 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden sticky-sidebar bg-white p-3">
                    <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
                        <div class="bg-primary bg-opacity-10 text-dmx rounded-3 p-2 me-2">
                            <i class="bi bi-list-stars fs-5"></i>
                        </div>
                        <h6 class="text-dark fw-black mb-0 font-14 text-uppercase">Danh Mục Thiết Bị</h6>
                    </div>

                    <div class="vertical-nav-dmx d-flex flex-column gap-1.5">
                        <button onclick="filterCategory('all')" class="v-nav-item active-v-cat">
                            <span class="v-nav-icon"><i class="bi bi-grid-1x2-fill"></i></span>
                            <span class="v-nav-text">Tất cả sản phẩm kho</span>
                            <span class="v-nav-badge">ALL</span>
                        </button>
                        <button onclick="filterCategory('1')" class="v-nav-item">
                            <span class="v-nav-icon"><i class="bi bi-laptop"></i></span>
                            <span class="v-nav-text">Máy Tính Xách Tay (Laptop)</span>
                            <span class="v-nav-badge">HOT</span>
                        </button>
                        <button onclick="filterCategory('2')" class="v-nav-item">
                            <span class="v-nav-icon"><i class="bi bi-pc-display"></i></span>
                            <span class="v-nav-text">Máy Tính Để Bàn (PC)</span>
                            <span class="v-nav-badge">NEW</span>
                        </button>
                        <button onclick="filterCategory('3')" class="v-nav-item">
                            <span class="v-nav-icon"><i class="bi bi-phone"></i></span>
                            <span class="v-nav-text">Điện Thoại Di Động</span>
                            <span class="v-nav-badge">BEST</span>
                        </button>
                        <button onclick="filterCategory('4')" class="v-nav-item">
                            <span class="v-nav-icon"><i class="bi bi-smartwatch"></i></span>
                            <span class="v-nav-text">Đồng Hồ Thông Minh</span>
                            <span class="v-nav-badge">SALE</span>
                        </button>
                        <button onclick="filterCategory('5')" class="v-nav-item">
                            <span class="v-nav-icon"><i class="bi bi-earbuds"></i></span>
                            <span class="v-nav-text">Phụ Kiện Công Nghệ</span>
                            <span class="v-nav-badge">99K</span>
                        </button>
                    </div>

                    <div class="mt-4 pt-3 border-top">
                        <label class="form-label font-11 fw-bold text-secondary text-uppercase mb-2">Bộ lọc giá bán</label>
                        <select id="priceFilter" class="form-select border rounded-3 font-13 bg-light-focus py-2" onchange="applyFilters()">
                            <option value="all">Hiển thị mọi mức giá</option>
                            <option value="under500">Phân khúc dưới 500 $</option>
                            <option value="500to1500">Tầm trung 500 $ - 1500 $</option>
                            <option value="over1500">Cao cấp trên 1500 $</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-8 col-xl-9">

                <div class="bg-white p-3 rounded-4 shadow-sm mb-3 d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <div class="d-flex align-items-center gap-2 flex-grow-1" style="min-width: 280px;">
                        <div class="position-relative w-100">
                            <input type="text" id="dmxSearchInput" oninput="applyFilters()" class="form-control border ps-4 py-2.5 rounded-3 font-13 bg-light-focus" placeholder="Tìm sản phẩm theo tên..." />
                            <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-3">
                        <span class="text-muted small font-12" id="product-count-info" style="display: none;">
                            <i class="bi bi-box-seam me-1"></i><span id="count-num">...</span> sản phẩm
                        </span>
                        <span class="text-muted small font-12" id="page-info" style="display: none;">
                            Trang <strong id="page-current">1</strong>/<strong id="page-total">1</strong>
                        </span>
                        <span class="text-muted small font-12"><i class="bi bi-sort-down-alt me-1"></i>Sắp xếp:</span>
                        <select id="sortFilter" class="form-select border rounded-3 font-13 bg-light-focus py-2" style="width: 200px;" onchange="applyFilters()">
                            <option value="default">Theo mặc định kho</option>
                            <option value="priceAsc">Giá tăng dần</option>
                            <option value="priceDesc">Giá giảm dần</option>
                            <option value="nameAsc">Tên sản phẩm A → Z</option>
                            <option value="newest">Mới nhất</option>
                        </select>
                    </div>
                </div>

                <div class="flash-sale-ribbon p-3 rounded-top-4 d-flex justify-content-between align-items-center text-white gap-2 shadow-sm">
                    <div class="d-flex align-items-center gap-2">
                        <h5 class="mb-0 fw-black text-uppercase tracking-wider font-15 italic-text text-flash-animate">
                            <i class="bi bi-lightning-charge-fill text-warning me-1"></i> GIỜ VÀNG FLASH SALE
                        </h5>
                        <div class="d-flex align-items-center gap-1 ms-3" id="flash-countdown">
                            <span class="timer-box" id="hours-box">00</span>:
                            <span class="timer-box" id="mins-box">00</span>:
                            <span class="timer-box" id="secs-box">00</span>
                        </div>
                    </div>
                    <span class="badge bg-white text-danger fw-bold rounded-pill px-3 font-11 shadow-sm">BẢO HÀNH CHÍNH HÃNG</span>
                </div>

                <div class="row g-2 bg-white p-3 rounded-bottom-4 shadow-sm border-x border-bottom mb-3" id="product-grid">
                    <!-- Skeleton loaders mặc định -->
                    @for (int i = 0; i < 8; i++) {
                        <div class="col-6 col-sm-4 col-md-4 col-xl-3 skeleton-card-wrap">
                            <div class="card h-100 p-2 border-smooth bg-white">
                                <div class="product-img-frame rounded-3 mb-2" style="height:170px;background:#f1f5f9;animation:shimmerDmx 1.5s infinite;"></div>
                                <div style="height:14px;background:#f1f5f9;border-radius:6px;margin-bottom:8px;animation:shimmerDmx 1.5s infinite;"></div>
                                <div style="height:14px;width:60%;background:#f1f5f9;border-radius:6px;animation:shimmerDmx 1.5s infinite;"></div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-center gap-2 mt-2 pb-3" id="pagination-area"></div>

            </div>
        </div>

    </div>
</div>

<style>
    .border-dmx {
        border-color: #00aef0 !important;
    }

    .text-dmx {
        color: #0072bc;
    }

    .font-96 {
        font-size: 6rem;
    }

    .style-tracking-tight {
        tracking-wider: -0.03em;
    }

    /* Hiệu ứng quét bóng cho nút Đăng bán */
    .btn-shine {
        position: relative;
        overflow: hidden;
    }

        .btn-shine::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -60%;
            width: 30%;
            height: 200%;
            background: rgba(255, 255, 255, 0.3);
            transform: rotate(30deg);
            transition: none;
            animation: shineEffect 4s infinite linear;
        }

    @@keyframes shineEffect {
        0% {
            left: -60%;
        }

        10% {
            left: 130%;
        }

        100% {
            left: 130%;
        }
    }

    /* Mega banner & Sub banner */
    .banner-overlay-particles {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background-image: radial-gradient(rgba(255,255,255,0.15) 1px, transparent 0);
        background-size: 24px 24px;
        opacity: 0.6;
        pointer-events: none;
    }

    .btn-white-mini {
        background-color: #fff;
        color: #333;
        text-decoration: none;
        border: none;
        transition: all 0.2s;
    }

        .btn-white-mini:hover {
            background-color: #f8f9fa;
            transform: scale(1.05);
        }

    .sub-banner-box {
        transition: transform 0.3s;
        cursor: pointer;
    }

        .sub-banner-box:hover {
            transform: translateY(-3px);
        }

    /* SIDEBAR ĐIỀU HƯỚNG DỌC ĐẶC SẮC CHẠY MƯỢT */
    .sticky-sidebar {
        position: sticky;
        top: 20px;
        z-index: 10;
    }

    .v-nav-item {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #fff;
        border: 1px solid #f1f5f9;
        border-radius: 10px;
        padding: 10px 14px;
        color: #334155;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        text-align: left;
    }

        .v-nav-item .v-nav-icon {
            font-size: 14px;
            color: #64748b;
            margin-right: 10px;
            transition: color 0.2s;
        }

        .v-nav-item .v-nav-text {
            flex-grow: 1;
            font-size: 13px;
            font-weight: 600;
        }

        .v-nav-item .v-nav-badge {
            font-size: 9px;
            padding: 2px 6px;
            background-color: #f1f5f9;
            border-radius: 4px;
            color: #64748b;
            font-weight: bold;
        }

        /* Hiệu ứng khi Hover vào mục điều hướng dọc */
        .v-nav-item:hover {
            background-color: #f0f9ff;
            border-color: #00aef0;
            color: #0072bc;
            padding-left: 18px;
        }

            .v-nav-item:hover .v-nav-icon {
                color: #00aef0;
            }

        /* Mục điều hướng dọc được kích hoạt (Active) */
        .v-nav-item.active-v-cat {
            background: linear-gradient(90deg, #0072bc, #00aef0);
            border-color: #0072bc;
            color: #fff;
            box-shadow: 0 4px 12px rgba(0, 114, 188, 0.2);
        }

            .v-nav-item.active-v-cat .v-nav-icon, .v-nav-item.active-v-cat .v-nav-badge {
                color: #fff;
                background-color: rgba(255,255,255,0.2);
            }

    /* Flash sale ribbon */
    .flash-sale-ribbon {
        background: linear-gradient(90deg, #e11d48, #f43f5e);
    }

    .italic-text {
        font-style: italic;
    }

    .text-flash-animate {
        animation: pulse 1.5s infinite;
    }

    .timer-box {
        background-color: #0f172a;
        color: #fff;
        padding: 3px 6px;
        border-radius: 5px;
        font-weight: bold;
        font-size: 13px;
        margin: 0 2px;
    }

    /* Cấu trúc lưới và Card sản phẩm Premium */
    .border-smooth {
        border: 1px solid #f1f5f9;
        border-radius: 12px;
    }

    .text-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 38px;
        line-height: 19px;
    }

    .object-contain-center {
        max-height: 150px;
        object-fit: contain;
        transition: transform 0.3s ease;
    }

    .bg-gift {
        background-color: #fff9f5;
        border: 1px dashed #f97316;
    }

    .style-lh-14 {
        line-height: 14px;
    }

    .bg-gradient-orange {
        background: linear-gradient(90deg, #f97316, #ef4444);
    }

    .bg-light-focus:focus {
        background-color: #fff !important;
        border-color: #00aef0 !important;
        box-shadow: 0 0 0 3px rgba(0, 174, 240, 0.15) !important;
        outline: none;
    }

    /* Hiệu ứng phóng to và đổ bóng Card */
    .dmx-premium-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .dmx-premium-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            border-color: #00aef0;
            z-index: 3;
        }

            .dmx-premium-card:hover .object-contain-center {
                transform: scale(1.06);
            }

    /* Nút bấm mua hàng và các icon mini */
    .btn-dmx-gradient {
        background: linear-gradient(90deg, #0072bc, #00aef0);
        color: #fff;
        border: none;
    }

        .btn-dmx-gradient:hover {
            background: linear-gradient(90deg, #005a96, #0096d1);
            color: #fff;
        }

    .btn-dmx-buy {
        border: 1px solid #00aef0;
        color: #00aef0;
        background: #fff;
    }

        .btn-dmx-buy:hover {
            background: #00aef0;
            color: #fff;
        }

    .btn-card-mini {
        width: 28px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        border-radius: 6px;
        font-size: 11px;
        background: #fff;
        transition: all 0.2s;
    }

        .btn-card-mini:hover {
            color: #fff !important;
            transform: translateY(-1px);
        }

    /* Kích thước font */
    .font-9 {
        font-size: 9px;
    }

    .font-10 {
        font-size: 10px;
    }

    .font-11 {
        font-size: 11px;
    }

    .font-12 {
        font-size: 12px;
    }

    .font-13 {
        font-size: 13px;
    }

    .font-14 {
        font-size: 14px;
    }

    .font-15 {
        font-size: 15px;
    }

    .font-16 {
        font-size: 16px;
    }

    .fw-black {
        font-weight: 900;
    }

    .fw-extrabold {
        font-weight: 800;
    }

    /* API Pagination and Shimmer */
    .page-btn {
        min-width: 36px;
        padding: 6px 10px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        border: 1px solid #e2e8f0;
        background: #fff;
        color: #475569;
        cursor: pointer;
        transition: all 0.2s;
    }
    .page-btn:hover:not(:disabled) {
        border-color: #00aef0;
        color: #0072bc;
        background: #f0f9ff;
    }
    .page-btn.active {
        background: linear-gradient(90deg, #0072bc, #00aef0);
        color: #fff;
        border-color: #0072bc;
        box-shadow: 0 4px 12px rgba(0, 114, 188, 0.25);
    }
    .page-btn:disabled {
        opacity: 0.4;
        cursor: default;
    }

    @@keyframes shimmerDmx {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }
    .skeleton-card-wrap .card {
        animation: pulse 1.5s ease-in-out infinite;
    }
</style>

@section Scripts {
    <script>
        // State management for API product catalog
        let currentPage = 1;
        let currentCategoryId = 0;
        let searchTimeout = null;
        const PAGE_SIZE = 12;

        // 1. Hàm lọc danh mục từ thanh điều hướng dọc
        function filterCategory(catId) {
            currentCategoryId = catId === 'all' ? 0 : parseInt(catId);
            currentPage = 1;

            // Thay đổi Class active cho mục được nhấn hiển thị
            document.querySelectorAll('.v-nav-item').forEach(btn => {
                btn.classList.remove('active-v-cat');
            });
            
            // Get click element properly even if triggered inside button children
            const btnEl = event.currentTarget || event.target.closest('.v-nav-item');
            if (btnEl) {
                btnEl.classList.add('active-v-cat');
            }

            loadProducts();
        }

        // 2. Bộ lọc xử lý đa điều kiện tổng hợp - Tích hợp API
        function applyFilters() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                currentPage = 1;
                loadProducts();
            }, 400);
        }

        // 3. Tải danh sách sản phẩm động từ API
        async function loadProducts() {
            const searchQuery = document.getElementById('dmxSearchInput').value.trim();
            const priceRange = document.getElementById('priceFilter').value;
            const sortType = document.getElementById('sortFilter').value;

            let url = `/api/products?page=${currentPage}&pageSize=${PAGE_SIZE}&sortBy=${sortType}`;
            if (searchQuery) url += `&search=${encodeURIComponent(searchQuery)}`;
            if (currentCategoryId > 0) url += `&categoryId=${currentCategoryId}`;
            
            if (priceRange === 'under500') {
                url += `&maxPrice=500`;
            } else if (priceRange === '500to1500') {
                url += `&minPrice=500&maxPrice=1500`;
            } else if (priceRange === 'over1500') {
                url += `&minPrice=1500`;
            }

            renderSkeletons();

            try {
                const response = await fetch(url);
                if (!response.ok) throw new Error('API request failed');
                const result = await response.json();

                renderProducts(result.data, result.pagination);
                renderPagination(result.pagination);

                // Update counts & info
                const countInfo = document.getElementById('product-count-info');
                const pageInfo = document.getElementById('page-info');
                if (countInfo && pageInfo) {
                    countInfo.style.display = 'inline-block';
                    pageInfo.style.display = 'inline-block';
                    document.getElementById('count-num').textContent = result.pagination.totalItems;
                    document.getElementById('page-current').textContent = result.pagination.currentPage;
                    document.getElementById('page-total').textContent = result.pagination.totalPages || 1;
                }

            } catch (error) {
                console.error('Error fetching products:', error);
                document.getElementById('product-grid').innerHTML = `
                    <div class="col-12 text-center py-5 text-muted">
                        <i class="bi bi-wifi-off display-3 text-muted opacity-30 d-block mb-2"></i>
                        <span class="font-13 fw-medium">Không thể kết nối đến máy chủ dữ liệu. Vui lòng thử lại sau.</span>
                    </div>`;
            }
        }

        // 4. Render sản phẩm động vào DOM
        function renderProducts(products, pagination) {
            const grid = document.getElementById('product-grid');
            if (!products || products.length === 0) {
                grid.innerHTML = `
                    <div class="col-12 text-center py-5 text-muted">
                        <i class="bi bi-folder-x display-3 text-muted opacity-30 d-block mb-2"></i>
                        <span class="font-13 fw-medium">Không tìm thấy sản phẩm nào phù hợp với bộ lọc hiện hành.</span>
                    </div>`;
                return;
            }

            const isAdmin = @(User.IsInRole("Admin") ? "true" : "false");

            grid.innerHTML = products.map(item => {
                const hasBestDeal = item.price > 1200;
                
                // Format price with commas
                const formattedPrice = formatNumber(item.price);
                const formattedOriginalPrice = formatNumber(item.originalPrice || (item.price * 1.25));

                const imgHtml = item.imageUrl 
                    ? `<img src="${item.imageUrl}" alt="${escHtml(item.name)}" class="img-fluid transition-img object-contain-center" />`
                    : `<div class="text-center text-muted">
                            <i class="bi bi-box-seam display-6 d-block mb-1 opacity-25"></i>
                            <span class="font-10">No Image</span>
                       </div>`;

                const adminActionsHtml = isAdmin ? `
                    <div class="d-flex gap-1">
                        <a href="/Admin/ProductManager/Update/${item.id}" class="btn btn-card-mini btn-outline-info" title="Sửa bản ghi">
                            <i class="bi bi-pencil-fill"></i>
                        </a>
                        <a href="/Admin/ProductManager/Delete/${item.id}" class="btn btn-card-mini btn-outline-danger" title="Xóa">
                            <i class="bi bi-trash3-fill"></i>
                        </a>
                    </div>
                ` : '';

                return `
                    <div class="col-6 col-sm-4 col-md-4 col-xl-3 product-item-card animate__animated animate__fadeIn">
                        <div class="card h-100 p-2 position-relative dmx-premium-card transition-card bg-white border-smooth">
                            <div class="position-absolute top-0 start-0 mt-2 ms-2 z-3 d-flex flex-column gap-1">
                                <span class="badge bg-warning text-dark font-9 fw-bold px-1.5 py-1 rounded-1 shadow-sm">Trả góp 0%</span>
                                ${hasBestDeal ? '<span class="badge bg-danger text-white font-9 fw-bold px-1.5 py-1 rounded-1 shadow-sm animate__animated animate__pulse animate__infinite">BEST DEAL</span>' : ''}
                            </div>

                            <div class="product-img-frame d-flex align-items-center justify-content-center p-2 mb-2 bg-white position-relative rounded-3" style="height: 170px; overflow: hidden;">
                                ${imgHtml}
                            </div>

                            <div class="card-body p-1 d-flex flex-column justify-content-between flex-grow-1">
                                <div>
                                    <h6 class="product-title-text font-13 fw-bold text-dark mb-1 text-clamp-2">${escHtml(item.name)}</h6>

                                    <div class="mb-2">
                                        <span class="text-danger fw-extrabold font-15">${formattedPrice} <small>$</small></span>
                                        <span class="text-muted text-decoration-line-through font-11 ms-1">${formattedOriginalPrice} $</span>
                                    </div>

                                    <div class="p-2 rounded-2 mb-2 bg-gift font-10 text-dark border-dashed-orange">
                                        <i class="bi bi-gift-fill text-danger me-1 animate__animated animate__swing animate__infinite animate__slower d-inline-block"></i> Quà tặng: Combo Bảo Hành Vàng
                                    </div>
                                </div>

                                <div>
                                    <div class="mb-2">
                                        <div class="progress rounded-pill position-relative shadow-inner" style="height: 14px; background-color: #fce8e6;">
                                            <div class="progress-bar progress-bar-striped progress-bar-animated rounded-pill bg-gradient-orange" role="progressbar" style="width: 72%;"></div>
                                            <span class="position-absolute w-100 text-center font-9 text-white fw-bold style-lh-14">Đã bán 72%</span>
                                        </div>
                                    </div>

                                    <div class="pt-2 border-top d-flex justify-content-between align-items-center gap-1">
                                        <a href="/Product/Display/${item.id}" class="btn btn-outline-secondary flex-grow-1 font-11 py-1.5 rounded-2 text-center fw-semibold transition-all">
                                            Chi tiết
                                        </a>
                                        <button onclick="addToCart(${item.id})" class="btn btn-primary flex-grow-1 font-11 py-1.5 rounded-2 text-center fw-bold transition-all">
                                            Thêm giỏ
                                        </button>
                                        ${adminActionsHtml}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        // 5. Hiển thị Skeleton Loader
        function renderSkeletons() {
            const grid = document.getElementById('product-grid');
            grid.innerHTML = Array(8).fill(0).map(() => `
                <div class="col-6 col-sm-4 col-md-4 col-xl-3 skeleton-card-wrap">
                    <div class="card h-100 p-2 border-smooth bg-white">
                        <div class="product-img-frame rounded-3 mb-2" style="height:170px;background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%);background-size:200%;animation:shimmerDmx 1.5s infinite;"></div>
                        <div style="height:14px;width:90%;background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%);background-size:200%;border-radius:6px;margin-bottom:8px;animation:shimmerDmx 1.5s infinite;"></div>
                        <div style="height:14px;width:60%;background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%);background-size:200%;border-radius:6px;animation:shimmerDmx 1.5s infinite;"></div>
                    </div>
                </div>
            `).join('');
        }

        // 6. Hiển thị thanh phân trang
        function renderPagination(pag) {
            const area = document.getElementById('pagination-area');
            if (!pag || pag.totalPages <= 1) { 
                area.innerHTML = ''; 
                return; 
            }

            let html = '';
            // Prev button
            html += `<button class="page-btn" ${!pag.hasPrevious ? 'disabled' : ''} onclick="goPage(${pag.currentPage - 1})">
                <i class="bi bi-chevron-left"></i>
            </button>`;

            // Page buttons
            const startPage = Math.max(1, pag.currentPage - 2);
            const endPage = Math.min(pag.totalPages, pag.currentPage + 2);
            for (let i = startPage; i <= endPage; i++) {
                const isActive = i === pag.currentPage;
                html += `<button class="page-btn ${isActive ? 'active' : ''}" onclick="goPage(${i})">${i}</button>`;
            }

            // Next button
            html += `<button class="page-btn" ${!pag.hasNext ? 'disabled' : ''} onclick="goPage(${pag.currentPage + 1})">
                <i class="bi bi-chevron-right"></i>
            </button>`;

            area.innerHTML = html;
        }

        // 7. Chuyển trang
        function goPage(page) {
            currentPage = page;
            loadProducts();
            document.getElementById('product-showcase').scrollIntoView({ behavior: 'smooth' });
        }

        // Helpers
        function formatNumber(num) {
            return parseFloat(num || 0).toLocaleString('vi-VN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        // Escape HTML to prevent XSS
        function escHtml(str) {
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        // 8. Hệ thống đồng hồ đếm ngược Flash Sale
        function runFlashSaleTimer() {
            let initialSeconds = 3 * 3600 + 12 * 60 + 44; // Thời gian chạy mặc định ban đầu

            const timer = setInterval(() => {
                if (initialSeconds <= 0) {
                    initialSeconds = 4 * 3600; // Tự động lặp lại khi hết chu kỳ
                }
                initialSeconds--;

                let h = Math.floor(initialSeconds / 3600);
                let m = Math.floor((initialSeconds % 3600) / 60);
                let s = initialSeconds % 60;

                document.getElementById('hours-box').innerText = String(h).padStart(2, '0');
                document.getElementById('mins-box').innerText = String(m).padStart(2, '0');
                document.getElementById('secs-box').innerText = String(s).padStart(2, '0');
            }, 1000);
        }

        document.addEventListener("DOMContentLoaded", () => {
            runFlashSaleTimer();
            loadProducts(); // Load initial products from API
        });
    </script>
}