@model LeMinhNhat_WebBanHang.Controllers.CompareTuple
@{
    ViewData["Title"] = "So Sánh Đối Đầu (Versus Mode)";
    var allProducts = ViewBag.AllProducts as List<LeMinhNhat_WebBanHang.Models.Product> ?? new List<LeMinhNhat_WebBanHang.Models.Product>();
}

<style>
    .compare-bg {
        background-color: #0b0f19;
        color: #f1f5f9;
        min-height: 100vh;
        font-family: 'Outfit', sans-serif;
    }

    .vs-glow {
        font-size: 3rem;
        font-weight: 900;
        background: linear-gradient(135deg, #ef4444, #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: 0 0 20px rgba(239, 68, 68, 0.4);
        position: relative;
    }

    .vs-circle {
        width: 70px; height: 70px;
        background: #1e293b;
        border: 3px solid #64748b;
        box-shadow: 0 0 15px rgba(255,255,255,0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: auto;
    }

    .p1-card {
        border: 2px solid #3b82f6 !important;
        box-shadow: 0 0 15px rgba(59, 130, 246, 0.2);
        background-color: #141b2d !important;
        color: #fff !important;
        border-radius: 16px;
    }

    .p2-card {
        border: 2px solid #ef4444 !important;
        box-shadow: 0 0 15px rgba(239, 68, 68, 0.2);
        background-color: #141b2d !important;
        color: #fff !important;
        border-radius: 16px;
    }

    .compare-select {
        background-color: #1e293b !important;
        border: 1px solid #475569 !important;
        color: white !important;
    }

    .stat-row {
        background: rgba(255,255,255,0.02);
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 8px;
        border: 1px solid rgba(255,255,255,0.05);
    }
</style>

<div class="compare-bg py-5">
    <div class="container px-4">
        <div class="text-center mb-5 animate__animated animate__fadeInDown">
            <span class="badge bg-danger text-white px-3 py-1.5 rounded-pill fw-bold font-10 tracking-widest mb-2">VERSUS SYSTEM</span>
            <h1 class="fw-black display-5 text-white">SO SÁNH ĐỐI ĐẦU</h1>
            <p class="text-muted">Độ phân giải thông số phần cứng & so khớp giá bán theo phong cách Gaming</p>
        </div>

        <div class="row g-4 align-items-center">
            <!-- Product 1 Section -->
            <div class="col-12 col-md-5 animate__animated animate__fadeInLeft">
                <div class="card p1-card p-4">
                    <div class="mb-4">
                        <label class="form-label text-info small fw-bold">CHỌN THIẾT BỊ 1</label>
                        <select id="p1-select" class="form-select compare-select py-2 rounded-3" onchange="reloadComparison()">
                            <option value="">-- Chọn sản phẩm --</option>
                            @foreach (var p in allProducts)
                            {
                                <option value="@p.Id" selected="@(Model.Product1?.Id == p.Id)">@p.Name (@p.Price.ToString("N0") $)</option>
                            }
                        </select>
                    </div>

                    @if (Model.Product1 != null)
                    {
                        <div class="text-center mb-4">
                            <img src="@Model.Product1.ImageUrl" alt="@Model.Product1.Name" class="img-fluid rounded border p-2 bg-white" style="height: 180px; object-fit: contain;" />
                            <h4 class="fw-bold mt-3 text-white">@Model.Product1.Name</h4>
                            <span class="fs-3 fw-bold text-info">@Model.Product1.Price.ToString("N2") $</span>
                        </div>

                        <!-- Stats specs -->
                        <div class="stat-row">
                            <span class="text-muted d-block small">Mô Tả & Cấu Hình</span>
                            <p class="mb-0 small text-white-50">@Model.Product1.Description</p>
                        </div>
                        <div class="stat-row">
                            <span class="text-muted d-block small">Mức Giá</span>
                            <div class="progress mt-2" style="height: 10px; background-color: #1e293b;">
                                <div class="progress-bar bg-info" style="width: @(Math.Min(100, (Model.Product1.Price / 2000m) * 100))%"></div>
                            </div>
                        </div>

                        <button onclick="addToCart(@Model.Product1.Id)" class="btn btn-info w-100 py-2.5 rounded-3 fw-bold mt-4 text-white shadow-sm">
                            <i class="bi bi-cart-plus-fill me-2"></i>MUA THIẾT BỊ NÀY
                        </button>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-cpu display-1 opacity-25"></i>
                            <p class="mt-3">Hãy chọn sản phẩm thứ nhất để so sánh</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Central VS Circle -->
            <div class="col-12 col-md-2 text-center py-3">
                <div class="vs-circle">
                    <span class="vs-glow">VS</span>
                </div>
            </div>

            <!-- Product 2 Section -->
            <div class="col-12 col-md-5 animate__animated animate__fadeInRight">
                <div class="card p2-card p-4">
                    <div class="mb-4">
                        <label class="form-label text-danger small fw-bold">CHỌN THIẾT BỊ 2</label>
                        <select id="p2-select" class="form-select compare-select py-2 rounded-3" onchange="reloadComparison()">
                            <option value="">-- Chọn sản phẩm --</option>
                            @foreach (var p in allProducts)
                            {
                                <option value="@p.Id" selected="@(Model.Product2?.Id == p.Id)">@p.Name (@p.Price.ToString("N0") $)</option>
                            }
                        </select>
                    </div>

                    @if (Model.Product2 != null)
                    {
                        <div class="text-center mb-4">
                            <img src="@Model.Product2.ImageUrl" alt="@Model.Product2.Name" class="img-fluid rounded border p-2 bg-white" style="height: 180px; object-fit: contain;" />
                            <h4 class="fw-bold mt-3 text-white">@Model.Product2.Name</h4>
                            <span class="fs-3 fw-bold text-danger">@Model.Product2.Price.ToString("N2") $</span>
                        </div>

                        <!-- Stats specs -->
                        <div class="stat-row">
                            <span class="text-muted d-block small">Mô Tả & Cấu Hình</span>
                            <p class="mb-0 small text-white-50">@Model.Product2.Description</p>
                        </div>
                        <div class="stat-row">
                            <span class="text-muted d-block small">Mức Giá</span>
                            <div class="progress mt-2" style="height: 10px; background-color: #1e293b;">
                                <div class="progress-bar bg-danger" style="width: @(Math.Min(100, (Model.Product2.Price / 2000m) * 100))%"></div>
                            </div>
                        </div>

                        <button onclick="addToCart(@Model.Product2.Id)" class="btn btn-danger w-100 py-2.5 rounded-3 fw-bold mt-4 text-white shadow-sm">
                            <i class="bi bi-cart-plus-fill me-2"></i>MUA THIẾT BỊ NÀY
                        </button>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-cpu display-1 opacity-25"></i>
                            <p class="mt-3">Hãy chọn sản phẩm thứ hai để so sánh</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function reloadComparison() {
            var p1 = $('#p1-select').val();
            var p2 = $('#p2-select').val();
            var query = [];
            if (p1) query.push('p1=' + p1);
            if (p2) query.push('p2=' + p2);
            window.location.href = '/Compare?' + query.join('&');
        }
    </script>
}
