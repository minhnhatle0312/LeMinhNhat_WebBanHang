<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LeMinhNhat_WebBanHang.styles.css" asp-append-version="true" />

    <style>
        :root {
            --primary-color: #2563eb;
            --primary-hover: #1d4ed8;
            --accent-color: #f59e0b;
            --dark-color: #0f172a;
            --light-bg: #f8fafc;
            --card-shadow: 0 15px 35px rgba(15, 23, 42, 0.05), 0 5px 15px rgba(15, 23, 42, 0.02);
            --gradient-accent: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
            --gradient-gold: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            --gradient-bronze: linear-gradient(135deg, #b45309 0%, #78350f 100%);
            --gradient-silver: linear-gradient(135deg, #94a3b8 0%, #475569 100%);
            --gradient-diamond: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
        }

        body {
            background-color: var(--light-bg);
            color: #334155;
            font-family: 'Outfit', sans-serif;
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Premium Smooth Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 6px;
            transition: all 0.3s;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* Navbar Styling */
        .navbar-custom {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(226, 232, 240, 0.8);
            position: sticky;
            top: 0;
            z-index: 1030;
            padding: 0.85rem 0;
            transition: all 0.3s ease;
        }

        .navbar-brand-custom {
            font-weight: 800;
            font-size: 1.55rem;
            color: var(--dark-color);
            text-decoration: none;
            display: flex;
            align-items: center;
            letter-spacing: -0.5px;
        }

        .navbar-brand-custom span {
            background: var(--gradient-accent);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-link-custom {
            font-weight: 600;
            font-size: 0.95rem;
            color: #475569;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            padding: 0.5rem 1rem;
            border-radius: 10px;
        }

        .nav-link-custom:hover, .nav-link-custom.active {
            color: var(--primary-color) !important;
            background: rgba(37, 99, 235, 0.06);
            transform: translateY(-1px);
        }

        /* Shopping Cart Drawer */
        .cart-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(15, 23, 42, 0.4);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            z-index: 1085;
            display: none;
        }

        .cart-drawer {
            position: fixed;
            top: 0; right: -440px;
            width: 440px; height: 100%;
            background: #fff;
            box-shadow: -15px 0 50px rgba(15, 23, 42, 0.12);
            z-index: 1090;
            transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            border-top-left-radius: 20px;
            border-bottom-left-radius: 20px;
            overflow: hidden;
        }

        .cart-drawer.open {
            right: 0;
        }

        .cart-header {
            background: var(--dark-color);
            color: #fff;
            padding: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .cart-items-wrapper {
            flex-grow: 1;
            overflow-y: auto;
            padding: 1.5rem;
        }

        .cart-item-row {
            display: flex;
            gap: 1.25rem;
            padding-bottom: 1.25rem;
            margin-bottom: 1.25rem;
            border-bottom: 1px solid #f1f5f9;
            align-items: center;
            transition: all 0.2s;
        }

        .cart-item-row:hover {
            transform: scale(1.01);
        }

        .cart-item-img {
            width: 70px; height: 70px;
            object-fit: contain;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 6px;
            background-color: #f8fafc;
        }

        .cart-badge-count {
            background-color: var(--accent-color);
            color: var(--dark-color);
            font-weight: 800;
            font-size: 0.75rem;
            padding: 0.25em 0.6em;
            border-radius: 20px;
        }

        /* Footer */
        footer {
            margin-top: auto;
            background-color: var(--dark-color);
            color: #94a3b8;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        footer h5 {
            color: #fff;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        footer a {
            color: #94a3b8;
            text-decoration: none;
            transition: all 0.25s;
        }

        footer a:hover {
            color: #fff;
            padding-left: 6px;
        }

        /* Floating Bot Chat */
        #ai-chat-bubble:hover {
            transform: scale(1.1) rotate(5deg);
            box-shadow: 0 15px 30px rgba(37,99,235,0.45) !important;
        }
        
        #ai-chat-bubble {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
        }
    </style>
</head>
<body>

    <!-- Header Navigation -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container px-4">
            <a class="navbar-brand-custom" asp-area="" asp-controller="Product" asp-action="Index">
                <i class="bi bi-cpu text-primary me-2 fs-3"></i>
                <span>TechStore</span>
            </a>
            
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list fs-2"></i>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4 gap-1">
                    <li class="nav-item">
                        <a class="nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" asp-area="" asp-controller="Product" asp-action="Index">Cửa Hàng</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Cart" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" asp-area="" asp-controller="Cart" asp-action="Index">Giỏ Hàng</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Compare" ? "active" : "")" asp-area="" asp-controller="Compare" asp-action="Index" style="position:relative;">
                            <i class="bi bi-bar-chart-steps me-1"></i>Đối Đầu
                            <span class="badge bg-danger ms-1" style="font-size:0.6rem;vertical-align:middle;">VS</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "FlashSale" ? "active" : "")" asp-area="" asp-controller="FlashSale" asp-action="Queue" style="position:relative;">
                            <i class="bi bi-lightning-charge-fill me-1 text-warning"></i>Flash Sale
                            <span class="badge bg-warning text-dark ms-1" style="font-size:0.6rem;vertical-align:middle;">HOT</span>
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link-custom text-warning" asp-area="Admin" asp-controller="ProductManager" asp-action="Index">
                                <i class="bi bi-shield-lock-fill me-1"></i>Khu Vực Admin
                            </a>
                        </li>
                    }
                </ul>

                <!-- Right Utility Bar -->
                <div class="d-flex align-items-center gap-3">
                    <!-- Search Input Form -->
                    <form class="d-none d-md-flex position-relative align-items-center" action="/Product/Index" method="get">
                        <input name="searchString" type="text" class="form-control rounded-pill border-0 bg-light px-4 py-2 font-13 shadow-sm" placeholder="Tìm kiếm linh kiện..." style="width: 240px; font-size: 0.85rem;" />
                        <button type="submit" class="btn border-0 position-absolute end-0 me-2 shadow-none"><i class="bi bi-search text-muted"></i></button>
                    </form>

                    <!-- Cart Trigger Button -->
                    <button class="btn btn-light rounded-circle p-2 position-relative shadow-sm" onclick="openCartDrawer()" title="Xem giỏ hàng nhanh" style="width: 42px; height: 42px;">
                        <i class="bi bi-bag text-dark fs-5"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="cart-badge-total">0</span>
                    </button>

                    <!-- User Account / Profile Section -->
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Render Body -->
    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- Cart Drawer Panels -->
    <div class="cart-overlay" id="cartOverlay" onclick="closeCartDrawer()"></div>
    <div class="cart-drawer" id="cartDrawer">
        <div class="cart-header">
            <h5 class="mb-0 fw-bold"><i class="bi bi-cart3 me-2"></i>Giỏ Hàng Của Bạn</h5>
            <button class="btn-close btn-close-white shadow-none" onclick="closeCartDrawer()"></button>
        </div>
        
        <div class="cart-items-wrapper" id="cart-drawer-list">
            <!-- Dynamic Cart Items via JS -->
            <div class="text-center py-5 text-muted" id="cart-drawer-empty">
                <i class="bi bi-bag-x fs-1 opacity-20 d-block mb-3"></i>
                Giỏ hàng trống. Hãy thêm sản phẩm!
            </div>
        </div>

        <div class="p-3 bg-light border-top" id="cart-drawer-footer" style="display: none;">
            <div class="d-flex justify-content-between mb-3 fw-bold">
                <span>Tổng cộng:</span>
                <span class="text-danger fs-5" id="cart-drawer-total">0.00 $</span>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary w-50 py-2.5 rounded-3 fw-bold font-13" asp-area="" asp-controller="Cart" asp-action="Index">Chi Tiết Giỏ</a>
                <a class="btn btn-primary w-50 py-2.5 rounded-3 fw-bold font-13 shadow" asp-area="" asp-controller="Cart" asp-action="Checkout">Thanh Toán</a>
            </div>
        </div>
    </div>

    <!-- Stunning Footer -->
    <footer class="py-5">
        <div class="container px-4">
            <div class="row g-4">
                <div class="col-12 col-md-4">
                    <a class="navbar-brand-custom text-white mb-3" asp-area="" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-cpu text-primary me-2"></i>
                        <span>TechStore</span>
                    </a>
                    <p class="small text-muted mb-3">Trang mua sắm điện thoại, laptop, linh kiện công nghệ chính hãng hàng đầu với thiết kế sang trọng, thời thượng.</p>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-light rounded-circle" style="width: 32px; height: 32px; padding: 4px;" href="#"><i class="bi bi-facebook"></i></a>
                        <a class="btn btn-sm btn-outline-light rounded-circle" style="width: 32px; height: 32px; padding: 4px;" href="#"><i class="bi bi-instagram"></i></a>
                        <a class="btn btn-sm btn-outline-light rounded-circle" style="width: 32px; height: 32px; padding: 4px;" href="#"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
                <div class="col-6 col-md-2 offset-md-1">
                    <h5>Danh Mục</h5>
                    <ul class="list-unstyled d-flex flex-column gap-2 small">
                        <li><a href="/Product/Index?categoryId=1">Laptops</a></li>
                        <li><a href="/Product/Index?categoryId=2">PCs / Desktops</a></li>
                        <li><a href="/Product/Index?categoryId=3">Smartphones</a></li>
                    </ul>
                </div>
                <div class="col-6 col-md-2">
                    <h5>Khách Hàng</h5>
                    <ul class="list-unstyled d-flex flex-column gap-2 small">
                        <li><a asp-area="" asp-controller="Cart" asp-action="Index">Giỏ Hàng</a></li>
                        <li><a asp-area="" asp-controller="Profile" asp-action="Index">Tài Khoản</a></li>
                        <li><a href="#">Hỗ Trợ Kỹ Thuật</a></li>
                    </ul>
                </div>
                <div class="col-12 col-md-3">
                    <h5>Sinh Viên Thực Hiện</h5>
                    <p class="small text-muted mb-1">Họ tên: Lê Minh Nhật</p>
                    <p class="small text-muted mb-1">Mã số: 2380601546</p>
                    <p class="small text-muted mb-1">Đại Học HUTECH</p>
                </div>
            </div>
            <hr class="my-4 border-secondary opacity-25">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 small text-muted">
                <span>&copy; @DateTime.Now.Year TechStore. All Rights Reserved.</span>
                <span class="d-flex gap-3">
                    <a href="#">Điều khoản sử dụng</a>
                    <a href="#">Chính sách bảo mật</a>
                </span>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function openCartDrawer() {
            $('#cartDrawer').addClass('open');
            $('#cartOverlay').fadeIn();
            loadCartDrawerData();
        }

        function closeCartDrawer() {
            $('#cartDrawer').removeClass('open');
            $('#cartOverlay').fadeOut();
        }

        function loadCartDrawerData() {
            $.ajax({
                url: '/Cart/GetCartSummary',
                type: 'GET',
                success: function(data) {
                    updateCartBadge(data.totalItems);
                    var $list = $('#cart-drawer-list');
                    $list.empty();

                    if (data.items && data.items.length > 0) {
                        $('#cart-drawer-empty').hide();
                        $('#cart-drawer-footer').show();
                        $('#cart-drawer-total').text(data.grandTotal.toFixed(2) + ' $');

                        data.items.forEach(function(item) {
                            var row = `
                                <div class="cart-item-row animate__animated animate__fadeIn">
                                    <img src="${item.productImage}" alt="${item.productName}" class="cart-item-img" />
                                    <div class="flex-grow-1">
                                        <h6 class="mb-0 fw-bold small text-truncate" style="max-width: 200px;">${item.productName}</h6>
                                        <div class="text-danger small fw-semibold">${item.price.toFixed(2)} $ <span class="text-muted">x${item.quantity}</span></div>
                                    </div>
                                    <button class="btn btn-sm btn-link text-muted shadow-none p-0" onclick="removeFromCart(${item.productId})">
                                        <i class="bi bi-trash fs-5"></i>
                                    </button>
                                </div>
                            `;
                            $list.append(row);
                        });
                    } else {
                        $list.append(`
                            <div class="text-center py-5 text-muted animate__animated animate__fadeIn" id="cart-drawer-empty">
                                <i class="bi bi-bag-x fs-1 opacity-20 d-block mb-3"></i>
                                Giỏ hàng trống. Hãy thêm sản phẩm!
                            </div>
                        `);
                        $('#cart-drawer-footer').hide();
                    }
                }
            });
        }

        function updateCartBadge(count) {
            $('#cart-badge-total').text(count);
            $('.id-cart-badge').text(count);
        }

        function addToCart(productId, qty) {
            var quantity = qty || 1;
            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { productId: productId, quantity: quantity },
                success: function(data) {
                    if (data.success) {
                        updateCartBadge(data.totalItems);
                        openCartDrawer();
                    } else {
                        alert(data.message || 'Lỗi khi thêm vào giỏ hàng.');
                    }
                },
                error: function() {
                    alert('Đã xảy ra lỗi.');
                }
            });
        }

        function removeFromCart(productId) {
            $.ajax({
                url: '/Cart/RemoveFromCart',
                type: 'POST',
                data: { productId: productId },
                success: function(data) {
                    if (data.success) {
                        loadCartDrawerData();
                        if (typeof loadCartPageData === 'function') {
                            loadCartPageData(); // If on the shopping cart full page, reload it too
                        }
                    } else {
                        alert(data.message || 'Lỗi khi xóa khỏi giỏ.');
                    }
                }
            });
        }

        // Initialize cart badge at page load
        $(document).ready(function() {
            $.ajax({
                url: '/Cart/GetCartSummary',
                type: 'GET',
                success: function(data) {
                    updateCartBadge(data.totalItems);
                }
            });
        });

        function toggleChatWindow() {
            var $win = $('#ai-chat-window');
            $win.toggle();
            if ($win.is(':visible')) {
                $('#ai-chat-messages').scrollTop($('#ai-chat-messages')[0].scrollHeight);
            }
        }

        function sendChatMessage() {
            var $input = $('#ai-chat-input');
            var text = $input.val().trim();
            if (!text) return;

            // Append user message
            $('#ai-chat-messages').append(`
                <div class="mb-2 text-end">
                    <span class="d-inline-block p-2 rounded-3 bg-primary text-white" style="max-width: 85%; text-align: left;">
                        ${text}
                    </span>
                </div>
            `);
            $input.val('');
            $('#ai-chat-messages').scrollTop($('#ai-chat-messages')[0].scrollHeight);

            // Fetch bot response
            $.ajax({
                url: '/Assistant/Ask',
                type: 'POST',
                data: { message: text },
                success: function(data) {
                    $('#ai-chat-messages').append(`
                        <div class="mb-2 text-start animate__animated animate__fadeIn">
                            <div class="d-inline-block p-2 rounded-3 bg-white text-dark shadow-sm border" style="max-width: 85%;">
                                ${data.reply}
                            </div>
                        </div>
                    `);
                    $('#ai-chat-messages').scrollTop($('#ai-chat-messages')[0].scrollHeight);
                }
            });
        }
    </script>

    <!-- Chat bot floating widget -->
    <div id="ai-chat-bubble" onclick="toggleChatWindow()" style="position: fixed; bottom: 25px; right: 25px; width: 60px; height: 60px; background: linear-gradient(135deg, #2563eb, #3b82f6); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; cursor: pointer; box-shadow: 0 10px 25px rgba(37,99,235,0.3); z-index: 1080; transition: transform 0.2s;">
        <i class="bi bi-robot fs-3 animate__animated animate__pulse animate__infinite"></i>
    </div>

    <div id="ai-chat-window" style="position: fixed; bottom: 95px; right: 25px; width: 360px; height: 480px; background: white; border-radius: 16px; box-shadow: 0 15px 35px rgba(0,0,0,0.15); z-index: 1080; display: none; flex-direction: column; overflow: hidden; border: 1px solid #e2e8f0;" class="animate__animated animate__fadeInUp">
        <div class="d-flex justify-content-between align-items-center p-3 bg-primary text-white">
            <h6 class="mb-0 fw-bold"><i class="bi bi-robot me-2"></i>TechBot Trợ Lý Cấu Hình</h6>
            <button class="btn-close btn-close-white shadow-none btn-sm" onclick="toggleChatWindow()"></button>
        </div>
        <div class="p-3 flex-grow-1 overflow-y-auto" id="ai-chat-messages" style="background-color: #f8fafc; font-size: 0.85rem;">
            <div class="mb-2 text-start">
                <span class="d-inline-block p-2 rounded-3 bg-light text-dark" style="max-width: 85%;">
                    👋 Xin chào! Tôi là trợ lý ảo TechBot. Bạn cần tư vấn lắp đặt PC hay mua laptop? Hãy nhắn tin cho tôi (ví dụ: 'build pc' hoặc 'laptop').
                </span>
            </div>
        </div>
        <div class="p-2 border-top bg-white d-flex gap-2">
            <input type="text" id="ai-chat-input" class="form-control form-control-sm rounded-pill border-0 bg-light px-3 shadow-none" placeholder="Nhập tin nhắn..." onkeydown="if(event.key === 'Enter') sendChatMessage()" />
            <button class="btn btn-sm btn-primary rounded-circle shadow-sm d-flex align-items-center justify-content-center" onclick="sendChatMessage()" style="width: 32px; height: 32px; flex-shrink: 0;"><i class="bi bi-send-fill" style="font-size: 11px;"></i></button>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>