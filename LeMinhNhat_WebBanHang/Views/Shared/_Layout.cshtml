<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LeMinhNhat TechStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LeMinhNhat_WebBanHang.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="custom-header">
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom-smooth">
            <div class="container py-2">
                <a class="navbar-brand brand-logo" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-laptop-fill text-primary me-2"></i>Nhật <span class="text-primary fw-bold">TechStore</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto menu-links">
                        <li class="nav-item">
                            <a class="nav-link-custom" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Trang Chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link-custom" asp-area="" asp-controller="Product" asp-action="Index">
                                <i class="bi bi-box-seam me-1"></i> Quản Lý Sản Phẩm
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link-custom" asp-area="" asp-controller="Category" asp-action="Index">
                                <i class="bi bi-tags me-1"></i> Quản Lý Danh Mục
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link-custom" asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-shield-lock me-1"></i> Chính Sách
                            </a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        <div class="search-box d-none d-xl-flex">
                            <input type="text" class="form-control form-control-sm rounded-pill" placeholder="Tìm sản phẩm..." />
                        </div>
                        <a href="#" class="btn btn-primary rounded-pill px-4 btn-sm shadow-sm">
                            <i class="bi bi-cart3 me-1"></i> Giỏ Hàng
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container content-wrapper">
        <main role="main" class="pb-5 pt-4 animate-fade-in">
            @RenderBody()
        </main>
    </div>

    <footer class="custom-footer">
        <div class="footer-bottom text-center py-3 border-top-smooth bg-light-gray">
            <div class="container text-muted">
                <small>&copy; @DateTime.Now.Year - <span class="fw-semibold">LeMinhNhat_WebBanHang</span>. Toàn bộ bản quyền được bảo lưu.</small>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>