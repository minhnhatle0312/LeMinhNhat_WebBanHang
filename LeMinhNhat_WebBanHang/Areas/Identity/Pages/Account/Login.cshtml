@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng Nhập Hệ Thống";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden animate__animated animate__fadeIn">
                <div class="p-4 p-md-5 bg-white">
                    <div class="text-center mb-4">
                        <div class="d-inline-flex bg-primary bg-opacity-10 text-primary p-3 rounded-circle mb-3">
                            <i class="bi bi-shield-lock-fill fs-2"></i>
                        </div>
                        <h3 class="fw-bold mb-1">Chào Mừng Trở Lại</h3>
                        <p class="text-muted small">Đăng nhập tài khoản TechStore để tiếp tục</p>
                    </div>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success rounded-3 small p-2 text-center mb-3">
                            <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]
                        </div>
                    }

                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <!-- Email -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email">Địa chỉ Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <!-- Password -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control rounded-3" autocomplete="current-password" aria-required="true" placeholder="Mật khẩu" />
                            <label asp-for="Input.Password">Mật khẩu</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <!-- Remember Me & Forgot Password -->
                        <div class="d-flex justify-content-between align-items-center mb-4 small">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label text-muted" asp-for="Input.RememberMe">
                                    Ghi nhớ đăng nhập
                                </label>
                            </div>
                            <a asp-page="./ForgotPassword" class="text-primary text-decoration-none fw-semibold">Quên mật khẩu?</a>
                        </div>

                        <button id="login-submit" type="submit" class="w-100 btn btn-primary py-3 rounded-3 fw-bold shadow-sm mb-3">
                            ĐĂNG NHẬP
                        </button>

                        <div class="text-center small">
                            <span class="text-muted">Chưa có tài khoản?</span>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary fw-bold text-decoration-none ms-1">Đăng ký mới</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
