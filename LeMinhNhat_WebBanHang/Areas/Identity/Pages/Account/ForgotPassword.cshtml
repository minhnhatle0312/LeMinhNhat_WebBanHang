@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Quên Mật Khẩu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden animate__animated animate__fadeIn">
                <div class="p-4 p-md-5 bg-white">
                    <div class="text-center mb-4">
                        <div class="d-inline-flex bg-warning bg-opacity-10 text-warning p-3 rounded-circle mb-3">
                            <i class="bi bi-key-fill fs-2"></i>
                        </div>
                        <h3 class="fw-bold mb-1">Khôi Phục Mật Khẩu</h3>
                        <p class="text-muted small">Nhập email và đặt lại mật khẩu mới cho tài khoản của bạn</p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <!-- Email -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="username" placeholder="name@example.com" />
                            <label asp-for="Input.Email">Địa chỉ Email của bạn</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <!-- NewPassword -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.NewPassword" class="form-control rounded-3" type="password" placeholder="Mật khẩu mới" />
                            <label asp-for="Input.NewPassword">Mật khẩu mới</label>
                            <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                        </div>

                        <!-- ConfirmNewPassword -->
                        <div class="form-floating mb-4">
                            <input asp-for="Input.ConfirmNewPassword" class="form-control rounded-3" type="password" placeholder="Xác nhận mật khẩu mới" />
                            <label asp-for="Input.ConfirmNewPassword">Xác nhận mật khẩu mới</label>
                            <span asp-validation-for="Input.ConfirmNewPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="w-100 btn btn-warning py-3 rounded-3 fw-bold shadow-sm mb-3">
                            ĐẶT LẠI MẬT KHẨU
                        </button>

                        <div class="text-center small">
                            <a asp-page="./Login" class="text-primary fw-bold text-decoration-none">Quay lại đăng nhập</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
