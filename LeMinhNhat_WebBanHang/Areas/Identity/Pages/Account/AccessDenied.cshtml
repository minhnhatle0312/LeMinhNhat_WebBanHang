@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Từ Chối Truy Cập";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 p-5 animate__animated animate__shakeX">
                <div class="d-inline-flex bg-danger bg-opacity-10 text-danger p-3 rounded-circle mb-4">
                    <i class="bi bi-shield-exclamation fs-1"></i>
                </div>
                <h3 class="fw-bold text-danger mb-2">Truy Cập Bị Từ Chối</h3>
                <p class="text-muted mb-4">Bạn không có quyền hạn truy cập vào khu vực này. Vui lòng liên hệ quản trị viên hoặc quay lại trang chủ.</p>
                <a class="btn btn-primary px-4 py-2.5 rounded-pill shadow fw-bold" asp-area="" asp-controller="Product" asp-action="Index">
                    <i class="bi bi-house-door me-2"></i>Quay Về Trang Chủ
                </a>
            </div>
        </div>
    </div>
</div>
