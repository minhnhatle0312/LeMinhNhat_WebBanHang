@{
    ViewData["Title"] = "Báo Cáo Doanh Thu";
    var totalRevenue = (decimal)ViewBag.TotalRevenue;
    var totalOrders = (int)ViewBag.TotalOrders;
    var aov = (decimal)ViewBag.AOV;
    var conversionRate = (double)ViewBag.ConversionRate;
    var sessions = (int)ViewBag.VisitorSessions;

    var chartLabels = ViewBag.ChartLabels as List<string> ?? new List<string>();
    var chartValues = ViewBag.ChartValues as List<decimal> ?? new List<decimal>();
    var topProducts = ViewBag.TopProducts as List<LeMinhNhat_WebBanHang.Areas.Admin.Controllers.TopSellingProductViewModel> ?? new List<LeMinhNhat_WebBanHang.Areas.Admin.Controllers.TopSellingProductViewModel>();
}

<!-- Title -->
<h3 class="fw-bold mb-4 text-dark"><i class="bi bi-graph-up-arrow me-2 text-primary"></i>Dashboard Doanh Thu</h3>

<!-- KPI Cards Grid -->
<div class="row g-4 mb-4">
    <!-- Card 1: Revenue -->
    <div class="col-12 col-sm-6 col-xl-3 animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 position-relative overflow-hidden kpi-card" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: #fff;">
            <div class="position-absolute bg-primary rounded-circle opacity-10" style="width: 120px; height: 120px; top: -60px; right: -60px; filter: blur(15px);"></div>
            <div class="d-flex align-items-center justify-content-between mb-3">
                <span class="small text-white-50 fw-bold text-uppercase tracking-wider">Tổng Doanh Thu</span>
                <div class="bg-primary bg-opacity-25 p-2.5 rounded-3 text-primary">
                    <i class="bi bi-currency-dollar fs-4"></i>
                </div>
            </div>
            <h3 class="fw-extrabold text-white mb-1">$@totalRevenue.ToString("N2")</h3>
            <span class="small text-success fw-bold"><i class="bi bi-arrow-up-right me-1"></i>+12.4% <span class="text-white-50 fw-normal">so với tháng trước</span></span>
        </div>
    </div>

    <!-- Card 2: Orders -->
    <div class="col-12 col-sm-6 col-xl-3 animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 position-relative overflow-hidden kpi-card" style="background: #fff; border-left: 5px solid #ffc107 !important;">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <span class="small text-secondary fw-bold text-uppercase tracking-wider">Tổng Đơn Hàng</span>
                <div class="bg-warning bg-opacity-10 p-2.5 rounded-3 text-warning">
                    <i class="bi bi-cart-check-fill fs-4"></i>
                </div>
            </div>
            <h3 class="fw-extrabold text-dark mb-1">@totalOrders</h3>
            <span class="small text-success fw-bold"><i class="bi bi-arrow-up-right me-1"></i>+8.2% <span class="text-secondary fw-normal">lượt đặt mua</span></span>
        </div>
    </div>

    <!-- Card 3: AOV -->
    <div class="col-12 col-sm-6 col-xl-3 animate__animated animate__fadeInUp" style="animation-delay: 0.3s;">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 position-relative overflow-hidden kpi-card" style="background: #fff; border-left: 5px solid #0dcaf0 !important;">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <span class="small text-secondary fw-bold text-uppercase tracking-wider">Giá Trị Trung Bình (AOV)</span>
                <div class="bg-info bg-opacity-10 p-2.5 rounded-3 text-info">
                    <i class="bi bi-bag-heart-fill fs-4"></i>
                </div>
            </div>
            <h3 class="fw-extrabold text-dark mb-1">$@aov.ToString("N2")</h3>
            <span class="small text-secondary">AOV tính trên đơn hàng đã giao</span>
        </div>
    </div>

    <!-- Card 4: Conversion Rate -->
    <div class="col-12 col-sm-6 col-xl-3 animate__animated animate__fadeInUp" style="animation-delay: 0.4s;">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 position-relative overflow-hidden kpi-card" style="background: #fff; border-left: 5px solid #198754 !important;">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <span class="small text-secondary fw-bold text-uppercase tracking-wider">Tỷ Lệ Chuyển Đổi</span>
                <div class="bg-success bg-opacity-10 p-2.5 rounded-3 text-success">
                    <i class="bi bi-percent fs-4"></i>
                </div>
            </div>
            <h3 class="fw-extrabold text-dark mb-1">@conversionRate%</h3>
            <span class="small text-secondary">Tính trên <b>@sessions</b> lượt truy cập</span>
        </div>
    </div>
</div>

<!-- Charts & Data Row -->
<div class="row g-4 mb-4">
    <!-- Chart: Revenue Trend -->
    <div class="col-12 col-lg-8 animate__animated animate__fadeInLeft">
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white h-100">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-bar-chart-line-fill text-primary me-2"></i>Biểu Đồ Xu Hướng Doanh Thu</h5>
                <span class="badge bg-light text-secondary border px-3 py-2 rounded-3 small fw-semibold">Gần nhất 6 tháng</span>
            </div>
            <div style="height: 320px; position: relative;">
                <canvas id="revenueTrendChart"></canvas>
            </div>
        </div>
    </div>

    <!-- List: Top Selling Products -->
    <div class="col-12 col-lg-4 animate__animated animate__fadeInRight">
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white h-100">
            <h5 class="fw-bold mb-4 border-bottom pb-2 text-dark"><i class="bi bi-fire text-danger me-2"></i>Sản Phẩm Bán Chạy Nhất</h5>
            
            <div class="d-flex flex-column gap-3">
                @if (topProducts.Any())
                {
                    int rankIdx = 1;
                    foreach (var item in topProducts)
                    {
                        <div class="d-flex align-items-center justify-content-between p-2 rounded-3 border-dashed hover-item transition">
                            <div class="d-flex align-items-center gap-3">
                                <span class="badge @(rankIdx == 1 ? "bg-danger" : (rankIdx == 2 ? "bg-warning" : "bg-secondary")) rounded-circle d-flex align-items-center justify-content-center" style="width: 24px; height: 24px; font-size: 11px;">@rankIdx</span>
                                <img src="@item.ProductImage" alt="@item.ProductName" class="rounded border p-1" style="width: 45px; height: 45px; object-fit: contain;" />
                                <div class="min-width-0">
                                    <h6 class="fw-bold text-dark text-truncate mb-0" style="max-width: 140px;" title="@item.ProductName">@item.ProductName</h6>
                                    <span class="text-muted small">Đơn giá: $@item.Price.ToString("N2")</span>
                                </div>
                            </div>
                            <div class="text-end">
                                <span class="fw-bold text-danger d-block">$@item.TotalRevenue.ToString("N2")</span>
                                <span class="badge bg-light text-dark rounded-pill small font-11">Đã bán: @item.QuantitySold</span>
                            </div>
                        </div>
                        rankIdx++;
                    }
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        Chưa có sản phẩm nào phát sinh doanh thu.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Load Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            // Read values injected by Controller
            var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chartLabels));
            var values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chartValues));

            var ctx = document.getElementById('revenueTrendChart').getContext('2d');
            var chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh Thu ($)',
                        data: values,
                        backgroundColor: 'rgba(13, 110, 253, 0.08)',
                        borderColor: '#0dcaf0',
                        borderWidth: 3,
                        pointBackgroundColor: '#0d6efd',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 5,
                        pointHoverRadius: 7,
                        tension: 0.35,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            backgroundColor: '#0f172a',
                            titleColor: '#fff',
                            bodyColor: '#fff',
                            padding: 10,
                            borderRadius: 8,
                            displayColors: false,
                            callbacks: {
                                label: function(context) {
                                    return ' Doanh thu: $' + context.raw.toLocaleString('en-US', { minimumFractionDigits: 2 });
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                font: {
                                    weight: 'bold'
                                }
                            }
                        },
                        y: {
                            grid: {
                                color: '#f1f5f9'
                            },
                            ticks: {
                                callback: function(value) {
                                    return '$' + value;
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>

    <style>
        .kpi-card {
            transition: all 0.25s ease-in-out;
        }
        .kpi-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05) !important;
        }
        .border-dashed {
            border-bottom: 1px dashed #e2e8f0;
        }
        .hover-item:hover {
            background-color: #f8fafc;
        }
        .transition {
            transition: all 0.2s ease-in-out;
        }
        .font-11 {
            font-size: 11px;
        }
    </style>
}
