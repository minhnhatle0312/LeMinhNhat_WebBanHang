@model IEnumerable<LeMinhNhat_WebBanHang.Areas.Admin.Controllers.UserRolesViewModel>
@{
    ViewData["Title"] = "Quản Lý Người Dùng";
    var roles = ViewBag.AvailableRoles as List<string> ?? new List<string>();
}

<h3 class="fw-bold mb-4 text-dark"><i class="bi bi-people me-2 text-warning"></i>Quản Lý Người Dùng</h3>

<!-- Message Toast Alerts -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 p-4 bg-white animate__animated animate__fadeIn">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr class="small text-secondary">
                    <th>Ảnh</th>
                    <th>Họ và Tên</th>
                    <th>Địa chỉ Email</th>
                    <th>Địa Chỉ</th>
                    <th>Độ Tuổi</th>
                    <th>Quyền Hạn (Roles)</th>
                    <th class="text-end" style="width: 250px;">Thay Đổi Vai Trò</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.User.ProfilePictureUrl))
                                {
                                    <img src="@item.User.ProfilePictureUrl" alt="@item.User.FullName" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px; font-size: 13px;">
                                        @(item.User.FullName?.Substring(0, Math.Min(item.User.FullName.Length, 2)).ToUpper() ?? "US")
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-bold text-dark font-13">@item.User.FullName</div>
                                <span class="text-muted small">Đăng ký ngày: @item.User.AccountCreatedAt.ToString("dd/MM/yyyy")</span>
                            </td>
                            <td>@item.User.Email</td>
                            <td>@(item.User.Address ?? "Chưa thiết lập")</td>
                            <td>@(item.User.Age?.ToString() ?? "N/A")</td>
                            <td>
                                @foreach (var r in item.Roles)
                                {
                                    @if (r == "Admin")
                                    {
                                        <span class="badge bg-danger px-2 py-1 rounded small">Quản Trị Viên</span>
                                    }
                                    else if (r == "Employee")
                                    {
                                        <span class="badge bg-info text-white px-2 py-1 rounded small">Nhân Viên</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-2 py-1 rounded small">Khách Hàng</span>
                                    }
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="ChangeRole" method="post" class="d-flex gap-1 align-items-center justify-content-end">
                                    <input type="hidden" name="userId" value="@item.User.Id" />
                                    <select name="newRole" class="form-select form-select-sm py-1.5 rounded-3" style="width: 140px;">
                                        @foreach (var roleName in roles)
                                        {
                                            <option value="@roleName" selected="@(item.Roles.Contains(roleName))">@roleName</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-warning fw-bold shadow-sm">Lưu</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            Chưa có người dùng nào đăng ký trên hệ thống.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
