@model IEnumerable<LeMinhNhat_WebBanHang.Models.Order>
@{
    ViewData["Title"] = "Quản Lý Đơn Hàng";
}

<h3 class="fw-bold mb-4 text-dark"><i class="bi bi-receipt-cutoff me-2 text-warning"></i>Quản Lý Đơn Hàng</h3>

<div class="card border-0 shadow-sm rounded-4 p-4 bg-white animate__animated animate__fadeIn">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr class="small text-secondary">
                    <th>Mã Đơn</th>
                    <th>Khách Hàng</th>
                    <th>Ngày Đặt</th>
                    <th>Tổng Tiền</th>
                    <th>Số Điện Thoại</th>
                    <th>Trạng Thái</th>
                    <th class="text-end">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">#@item.Id</td>
                            <td>
                                <div class="fw-bold text-dark font-13">@(item.User?.FullName ?? "N/A")</div>
                                <span class="text-muted small">@item.User?.Email</span>
                            </td>
                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="fw-bold text-danger">@item.TotalAmount.ToString("N2") $</td>
                            <td>@item.PhoneNumber</td>
                            <td>
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark px-2.5 py-1.5 rounded-pill small">Chờ Duyệt</span>
                                }
                                else if (item.Status == "Approved")
                                {
                                    <span class="badge bg-info text-white px-2.5 py-1.5 rounded-pill small">Đã Duyệt</span>
                                }
                                else if (item.Status == "Shipped")
                                {
                                    <span class="badge bg-primary text-white px-2.5 py-1.5 rounded-pill small">Đang Giao</span>
                                }
                                else if (item.Status == "Completed")
                                {
                                    <span class="badge bg-success text-white px-2.5 py-1.5 rounded-pill small">Hoàn Thành</span>
                                }
                                else if (item.Status == "Cancelled")
                                {
                                    <span class="badge bg-danger text-white px-2.5 py-1.5 rounded-pill small">Đã Hủy</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-eye-fill"></i> Chi Tiết
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            Chưa có đơn hàng nào phát sinh trên hệ thống.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
