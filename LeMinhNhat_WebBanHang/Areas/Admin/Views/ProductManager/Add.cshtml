@model LeMinhNhat_WebBanHang.Models.Product
@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3 rounded-pill mb-3">
        <i class="bi bi-arrow-left me-1"></i> Quay về danh sách
    </a>
    <h3 class="fw-bold text-dark"><i class="bi bi-plus-circle-fill me-2 text-warning"></i>Thêm Sản Phẩm Mới</h3>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white animate__animated animate__fadeIn">
            <form asp-action="Add" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold small text-secondary">Tên sản phẩm</label>
                    <input asp-for="Name" class="form-control py-2.5 rounded-3" placeholder="Nhập tên sản phẩm..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label fw-semibold small text-secondary">Giá bán ($)</label>
                        <input asp-for="Price" class="form-control py-2.5 rounded-3" placeholder="Ví dụ: 99.99" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label fw-semibold small text-secondary">Danh mục ngành hàng</label>
                        <select asp-for="CategoryId" asp-items="@ViewBag.Categories" class="form-select py-2.5 rounded-3">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold small text-secondary">Mô tả sản phẩm</label>
                    <textarea asp-for="Description" class="form-control rounded-3" rows="4" placeholder="Nhập mô tả sản phẩm chi tiết..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold small text-secondary">Hình ảnh đại diện</label>
                    <input name="imageUrl" type="file" class="form-control" accept="image/*" />
                </div>

                <button type="submit" class="btn btn-warning w-100 py-3 rounded-3 fw-bold shadow-sm">
                    XÁC NHẬN THÊM SẢN PHẨM
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
