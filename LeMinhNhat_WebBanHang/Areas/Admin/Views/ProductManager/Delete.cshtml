@model LeMinhNhat_WebBanHang.Models.Product
@{
    ViewData["Title"] = "Xóa Sản Phẩm";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3 rounded-pill mb-3">
        <i class="bi bi-arrow-left me-1"></i> Quay về danh sách
    </a>
    <h3 class="fw-bold text-dark"><i class="bi bi-trash3-fill me-2 text-danger"></i>Xóa Sản Phẩm</h3>
</div>

<div class="row justify-content-center animate__animated animate__fadeIn">
    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white text-center">
            <div class="d-inline-flex bg-danger bg-opacity-10 text-danger p-3 rounded-circle mb-4">
                <i class="bi bi-exclamation-triangle fs-1"></i>
            </div>
            
            <h4 class="fw-bold mb-3 text-dark">Bạn có chắc chắn muốn xóa sản phẩm này?</h4>
            
            <div class="card bg-light border-0 p-3 mb-4 rounded-3 text-start">
                <div class="d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="rounded border p-1" style="width: 60px; height: 60px; object-fit: contain; background: #fff;" />
                    }
                    <div>
                        <h6 class="fw-bold text-dark mb-0">@Model.Name</h6>
                        <span class="text-danger fw-semibold">@Model.Price.ToString("N2") $</span>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary w-50 py-2.5 rounded-3 fw-bold">Hủy Bỏ</a>
                    <button type="submit" class="btn btn-danger w-50 py-2.5 rounded-3 fw-bold shadow-sm">Xác Nhận Xóa</button>
                </div>
            </form>
        </div>
    </div>
</div>
